---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SmartEditor } from '@/components/tools/ImageLab';
---
<BaseLayout currentPage="tools"
  title="圖片處理工廠 | 挫屎勇的實用工具"
  description="線上圖片壓縮、裁切、縮放工具。純瀏覽器處理，你的照片不會被上傳到伺服器，安心使用！"
>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <h1 class="text-3xl font-bold text-base-50 mb-4">🖼️ 圖片處理工廠</h1>

    <!-- 安全提示 -->
    <div class="bg-accent-cyan/20 border border-accent-cyan rounded-lg p-4 mb-6">
      <h5 class="font-bold text-accent-cyan mb-1">🔒 你的照片很安全</h5>
      <p class="text-base-400">
        所有處理都在瀏覽器完成，圖片<strong class="text-base-50">不會上傳到任何伺服器</strong>。
      </p>
    </div>

    <!-- React SmartEditor -->
    <SmartEditor client:load />
  </div>
</BaseLayout>

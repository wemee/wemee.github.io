---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QRCodeTool from './_QRCodeTool';
---
<BaseLayout currentPage="tools"
  title="QR Code 工具 | 挫屎勇的實用工具"
  description="QR Code 解碼與產生工具。上傳圖片解析 QR Code，或輸入文字產生 QR Code。純瀏覽器處理，資料不上傳伺服器。"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <h1 class="text-3xl font-bold text-base-50 mb-4">📱 QR Code 工具</h1>

    <!-- 功能說明 -->
    <div class="bg-accent-cyan/20 border border-accent-cyan rounded-lg p-4 mb-6">
      <h5 class="font-bold text-accent-cyan mb-1">🔒 所有處理都在瀏覽器完成</h5>
      <p class="text-base-400 mb-0">
        你的圖片和文字<strong class="text-base-50">不會上傳到任何伺服器</strong>，放心使用。
      </p>
    </div>

    <!-- React Component -->
    <QRCodeTool client:load />
  </div>
</BaseLayout>

<script is:inline src="/tools/qrcode/jsQR.min.js"></script>
<script is:inline src="/tools/qrcode/qrcode-generator.min.js"></script>

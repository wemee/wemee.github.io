---
// Legacy URL. The page moved to /tools/todo/ — name now matches content.
// GitHub Pages is static-only, so we redirect via meta refresh + a JS
// replace() so back-button doesn't get stuck on this stub, plus a canonical
// link tag for search engines.
const target = '/tools/todo/';
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>已搬遷至「免登入待辦清單」</title>
    <script is:inline define:vars={{ target }}>
      // Use replace() so this stub doesn't sit in browser history.
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>此頁面已搬遷，前往 <a href={target}>免登入待辦清單</a>。</p>
  </body>
</html>

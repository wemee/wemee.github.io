---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
import DigitRecognition from './_DigitRecognition';
---
<BaseLayout currentPage="tools"
  title="手寫數字辨識 | 挫屎勇的實用工具"
  description="在畫布上手寫數字，AI 即時辨識！使用 TensorFlow.js 在瀏覽器端運行深度學習模型，支援手機與電腦。"
>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <h1 class="text-3xl font-bold text-base-50 mb-4">✏️ 手寫數字辨識</h1>

    <!-- 功能說明 -->
    <div class="bg-accent-cyan/20 border border-accent-cyan rounded-lg p-4 mb-6">
      <h5 class="font-bold text-accent-cyan mb-1">🧠 AI 在你的瀏覽器裡運行</h5>
      <p class="text-base-400">
        使用深度學習模型辨識手寫數字，<strong class="text-base-50">不需要網路連線</strong>，所有運算都在本地完成。
      </p>
    </div>

    <DigitRecognition client:load />

    <!-- 技術說明 -->
    <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden mt-6 mb-8">
      <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 flex items-center">
        <span class="flex items-center">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-accent-blue text-base-50 text-sm font-bold mr-2">?</span>
          這是怎麼運作的？
        </span>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <h6 class="font-bold text-base-50 mb-1">模型架構</h6>
            <p class="text-sm text-base-600">
              輕量級 CNN，2 層卷積 + 1 層全連接，MNIST 準確度 98.77%。
            </p>
          </div>
          <div>
            <h6 class="font-bold text-base-50 mb-1">前端推理</h6>
            <p class="text-sm text-base-600">
              TensorFlow.js 載入模型，瀏覽器端運算，約 420KB。
            </p>
          </div>
          <div>
            <h6 class="font-bold text-base-50 mb-1">圖片預處理</h6>
            <p class="text-sm text-base-600">
              筆跡置中、縮放 28×28、正規化為黑底白字。
            </p>
          </div>
          <div>
            <h6 class="font-bold text-base-50 mb-1">Saliency Map</h6>
            <p class="text-sm text-base-600">
              計算輸入梯度，顯示哪些像素對預測影響最大。
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <RelatedNotes currentPath="/tools/digit-recognition/" />
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.17.0/dist/tf.min.js"></script>

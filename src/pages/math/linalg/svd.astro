---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LinalgPageNav from '@/components/LinalgPageNav.astro';
import { SVD_PRESETS } from '@/lib/math/linalg/svdPresets';
import katex from 'katex';
import 'katex/dist/katex.min.css';

const tex = (s: string, display = false) =>
  katex.renderToString(s, { displayMode: display, throwOnError: false, output: 'html' });
---
<BaseLayout
  currentPage="math"
  title="奇異值分解 SVD"
  description="任何矩陣都能拆成「旋轉 → 拉伸 → 旋轉」三步 — CS 線代的最高峰。"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-16">
    <a href="/math/linalg/" class="text-accent-blue hover:underline text-sm">← 回線性代數專區</a>

    <header class="mt-4 mb-6 text-center">
      <p class="text-base-400 text-sm tracking-widest uppercase mb-2">Chapter 3 · 分解與譜論</p>
      <h1 class="text-3xl md:text-4xl font-bold text-base-50 mb-2">🔱 奇異值分解 SVD</h1>
      <p class="text-base-400 max-w-2xl mx-auto" set:html={'任何矩陣 ' + tex('A = U \\Sigma V^\\top') + ' — 不必方陣、不必可逆、不必對稱。三個步驟：先旋轉、再沿軸拉伸、再旋轉。'}></p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- 左：3D 視覺化 -->
      <div class="lg:col-span-2">
        <div id="scene-container" class="rounded-lg border border-base-600 bg-base-900 overflow-hidden shadow-lg" style="height: 60vh; min-height: 420px;"></div>

        <!-- 階段切換 -->
        <div class="mt-3 rounded-lg border border-accent-cyan/40 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-accent-cyan/10 border-b border-accent-cyan/40 font-bold text-accent-cyan text-sm">
            🎬 變換階段
          </div>
          <div class="p-3 grid grid-cols-2 sm:grid-cols-4 gap-2">
            <button data-phase="0" class="phase-btn active px-2 py-2 text-xs rounded transition">
              0 · 單位球
            </button>
            <button data-phase="1" class="phase-btn px-2 py-2 text-xs rounded transition" set:html={'1 · 旋轉 ' + tex('V^\\top')}></button>
            <button data-phase="2" class="phase-btn px-2 py-2 text-xs rounded transition" set:html={'2 · 拉伸 ' + tex('\\Sigma')}></button>
            <button data-phase="3" class="phase-btn px-2 py-2 text-xs rounded transition" set:html={'3 · 旋轉 ' + tex('U')}></button>
          </div>
          <p id="phase-hint" class="px-4 py-2 bg-base-900/60 border-t border-base-600 text-xs text-base-400 italic"></p>
        </div>

        <!-- 低秩近似 -->
        <div class="mt-3 rounded-lg border border-accent-yellow/40 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-accent-yellow/10 border-b border-accent-yellow/40 font-bold text-accent-yellow text-sm">
            🧪 低秩近似 (Low-Rank Approximation)
          </div>
          <div class="p-3 grid grid-cols-3 gap-2">
            <button data-rank="1" class="rank-btn px-2 py-2 text-xs rounded transition" set:html={'保留 ' + tex('\\sigma_1')}></button>
            <button data-rank="2" class="rank-btn px-2 py-2 text-xs rounded transition" set:html={'保留 ' + tex('\\sigma_1, \\sigma_2')}></button>
            <button data-rank="3" class="rank-btn active px-2 py-2 text-xs rounded transition" set:html={'全部 (Rank 3)'}></button>
          </div>
          <p class="px-4 py-2 bg-base-900/60 border-t border-base-600 text-xs text-base-400 italic">捨掉最小的奇異值，看 A 被「壓縮」後的近似 — 影像壓縮與推薦系統的核心。</p>
        </div>
      </div>

      <!-- 右：控制 -->
      <div class="space-y-4">
        <!-- Preset -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-blue text-sm">
            🎯 預設矩陣
          </div>
          <div class="p-3 grid grid-cols-2 gap-2">
            {SVD_PRESETS.map((p) => (
              <button data-preset={p.id} class="px-2 py-2 text-xs rounded bg-base-700 hover:bg-accent-blue/30 border border-base-600 text-base-100 transition text-left" title={p.hint}>
                {p.label}
              </button>
            ))}
          </div>
          <div class="px-4 py-2 bg-base-900/60 border-t border-base-600">
            <p id="preset-hint" class="text-xs text-base-400 italic min-h-[2.5em]">點按鈕，或直接編輯下面的矩陣。</p>
          </div>
        </div>

        <!-- 矩陣輸入 -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-base-100 text-sm flex justify-between items-center">
            <span set:html={'任意矩陣 ' + tex('A')}></span>
            <button id="reset-matrix" class="px-2 py-0.5 text-xs rounded bg-base-700 hover:bg-base-600 border border-base-600">重設</button>
          </div>
          <div class="p-3">
            <div id="matrix-grid" class="grid grid-cols-3 gap-1"></div>
          </div>
        </div>

        <!-- 奇異值 -->
        <div class="rounded-lg border border-accent-green/40 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-accent-green/10 border-b border-accent-green/40 font-bold text-accent-green text-sm">
            🌟 奇異值 (大→小)
          </div>
          <div class="p-4 font-mono text-sm">
            <div id="sigma-list"></div>
            <hr class="border-base-600 my-2">
            <div class="flex justify-between"><span class="text-base-400">秩 (rank)</span><span id="rank-val" class="text-base-50 font-bold">3</span></div>
            <div class="flex justify-between"><span class="text-base-400" set:html={'條件數 ' + tex('\\kappa = \\sigma_1/\\sigma_3')}></span><span id="cond-val" class="text-base-50 font-bold">1</span></div>
            <p id="cond-hint" class="text-xs text-base-400 mt-1 min-h-[1.2em]"></p>
          </div>
        </div>

        <!-- U / V matrices -->
        <details class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <summary class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-base-100 text-sm cursor-pointer hover:bg-base-600/50 transition">
            🔍 展開看 U 與 V 矩陣
          </summary>
          <div class="p-3 space-y-3 font-mono text-xs">
            <div>
              <div class="text-base-400 mb-1" set:html={tex('U =')}></div>
              <div id="u-grid" class="grid grid-cols-3 gap-1"></div>
            </div>
            <div>
              <div class="text-base-400 mb-1" set:html={tex('V =')}></div>
              <div id="v-grid" class="grid grid-cols-3 gap-1"></div>
            </div>
          </div>
        </details>
      </div>
    </div>

    <!-- 教學內容 -->
    <section class="mt-12 max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-base-50 mb-4">📖 任何矩陣 = 旋轉 → 拉伸 → 旋轉</h2>

      <div class="space-y-4 text-base-300 leading-relaxed">
        <p>奇異值分解（Singular Value Decomposition）說的是一個驚人的事實：<strong class="text-base-50">任何矩陣（不必方陣、不必可逆、不必對稱）都能拆成三步</strong></p>

        <div class="my-6 flex justify-center" set:html={tex("A \\;=\\; U \\,\\Sigma\\, V^\\top", true)} />

        <p>其中：</p>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><span set:html={tex('V')} />、<span set:html={tex('U')} /> 是<strong class="text-base-50">正交矩陣</strong>（純旋轉/反射，不會改變長度）</li>
          <li><span set:html={tex('\\Sigma')} /> 是<strong class="text-base-50">對角矩陣</strong>，對角線上是<strong class="text-base-50">奇異值</strong>（singular values）<span set:html={tex('\\sigma_1 \\ge \\sigma_2 \\ge \\sigma_3 \\ge 0')} /></li>
        </ul>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🎬 用上面那個動畫看四個階段</h3>
        <p>按上面的「變換階段」按鈕，看單位球被 <span set:html={tex('A')} /> 變形的過程：</p>
        <ol class="list-decimal list-inside space-y-2 ml-2">
          <li><strong>階段 0：單位球</strong> — 起點是個球。三條彩色箭頭是 <span set:html={tex('V')} /> 的三個欄向量（「輸入主方向」）。</li>
          <li><strong>階段 1：套用 <span set:html={tex('V^\\top')} /></strong> — 球還是球（旋轉不改變球形），但三條箭頭轉到 X/Y/Z 軸了。意思是「先把輸入空間轉到主方向對齊的座標系」。</li>
          <li><strong>階段 2：套用 <span set:html={tex('\\Sigma')} /></strong> — 球變橢球！沿著 X/Y/Z 軸各自被拉伸 <span set:html={tex('\\sigma_1, \\sigma_2, \\sigma_3')} /> 倍。橢球的主軸長度就是奇異值。</li>
          <li><strong>階段 3：套用 <span set:html={tex('U')} /></strong> — 橢球被旋轉到最終位置。三條箭頭現在是 <span set:html={tex('\\sigma_i \\,u_i')} />（輸出主方向 × 對應奇異值）。</li>
        </ol>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">💎 SVD vs 特徵分解：誰大誰小</h3>
        <p>SVD 是<a href="/math/linalg/eigen" class="text-accent-blue hover:underline">特徵分解</a>的進階推廣：</p>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><strong>特徵分解</strong>：只能用在<strong class="text-base-50">方陣</strong>，特徵值可能是複數，可能不可對角化（需要 Jordan form）。</li>
          <li><strong>SVD</strong>：<strong class="text-base-50">任何矩陣</strong>都能做，奇異值<strong class="text-base-50">永遠是實數且 ≥ 0</strong>，<strong class="text-base-50">永遠存在</strong>。</li>
        </ul>
        <p>數學上的關係：<span set:html={tex('\\sigma_i^2')} /> 是 <span set:html={tex('A^\\top A')} /> 的特徵值。也就是說，SVD 本質上是「先把矩陣弄成對稱的（乘上 <span set:html={tex('A^\\top')} />），再做特徵分解」。</p>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🗜️ 低秩近似 — 影像壓縮的魔術</h3>
        <p>奇異值是<strong class="text-base-50">按重要性排序</strong>的：<span set:html={tex('\\sigma_1')} /> 抓最多「能量」、<span set:html={tex('\\sigma_2')} /> 第二多… 最小的 <span set:html={tex('\\sigma_k')} /> 可能比 <span set:html={tex('\\sigma_1')} /> 小幾百倍。</p>

        <p>把小的奇異值設成 0，就得到 <span set:html={tex('A')} /> 的「<strong class="text-base-50">低秩近似</strong>」：</p>
        <div class="my-4 flex justify-center" set:html={tex("A_k = \\sum_{i=1}^{k} \\sigma_i\\, u_i\\, v_i^\\top \\quad (k < n)", true)} />

        <p><strong class="text-base-50">Eckart-Young 定理</strong>說這個 <span set:html={tex('A_k')} /> 是「保留 k 個成分下，最接近原矩陣的近似」。試試上面的<strong class="text-accent-yellow">低秩近似</strong>按鈕，看橢球變形 — 失去最小的軸幾乎看不出差別。</p>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🚀 CS 上的核心應用</h3>
        <ul class="list-disc list-inside space-y-2 ml-2">
          <li><strong class="text-base-50">影像壓縮</strong>：把影像當成矩陣，丟掉小的奇異值。保留前 10% 的 σ 就能還原 90% 的視覺內容。JPEG 的 DCT 是這個思路的近親。</li>
          <li><strong class="text-base-50">推薦系統</strong>：用戶 × 電影評分矩陣做 SVD，前幾個奇異值對應「潛在因子」（動作片偏好、文藝片偏好...）。Netflix Prize 的核心。</li>
          <li><strong class="text-base-50">PCA (主成分分析)</strong>：對中心化的資料矩陣做 SVD，左奇異向量就是主成分。比直接算 covariance 矩陣的特徵分解數值上更穩定。</li>
          <li><strong class="text-base-50">LSA (潛在語意分析)</strong>：文件 × 詞彙矩陣 SVD，奇異向量代表潛在的「主題」。</li>
          <li><strong class="text-base-50">偽反矩陣 (pseudoinverse)</strong>：當 A 不是方陣或不可逆時，<span set:html={tex('A^+ = V \\Sigma^+ U^\\top')} />（把 σᵢ 取倒數，0 保留 0）給出最小平方意義下的「最佳解」。</li>
          <li><strong class="text-base-50">條件數判斷數值穩定性</strong>：<span set:html={tex('\\kappa(A) = \\sigma_1 / \\sigma_n')} />。κ 大代表矩陣「近乎奇異」，數值計算會放大誤差。</li>
        </ul>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🎮 動手試試</h3>
        <ol class="list-decimal list-inside space-y-2 ml-2">
          <li>點 <strong class="text-accent-blue">沿軸拉伸</strong> → σ = (3, 1.5, 0.5)，秩 = 3。把低秩近似設成「保留 σ₁」 → 橢球變一條棒。</li>
          <li>點 <strong class="text-accent-blue">旋轉 45°</strong> → σ = (1, 1, 1)。雖然 U, V 都不是單位矩陣，但 Σ 是 — 純旋轉沒有主軸方向，每個方向都「等長」。</li>
          <li>點 <strong class="text-accent-red">Rank 2</strong> → σ₃ = 0，橢球變成平面圓盤。這就是「降維」的視覺意義。</li>
          <li>點 <strong class="text-accent-red">條件數大</strong> → σ₁/σ₃ = 1000，看條件數 κ 飆高。這種矩陣求逆會放大誤差 1000 倍。</li>
          <li>用<strong>「變換階段」</strong>按鈕一步一步看 SVD 分解的過程。</li>
        </ol>

        <div class="my-6 p-4 rounded bg-base-800/60 border-l-4 border-accent-cyan">
          <p class="text-base-50 font-bold mb-1">💡 演算法細節</p>
          <p class="text-sm">這頁的 SVD 用「<span set:html={tex('A^\\top A')} /> 路線」：對 <span set:html={tex('A^\\top A')} />（對稱正半定）做<a href="/math/linalg/eigen" class="text-accent-cyan hover:underline">特徵分解</a>得到 V 跟 σ²，再用 <span set:html={tex('u_i = A v_i / \\sigma_i')} /> 算 U。實務上的 SVD 庫（LAPACK 等）用更穩定的雙對角化 + QR 迭代，但思路一樣。</p>
        </div>
      </div>
    </section>

    <LinalgPageNav slug="svd" />
  </div>

  <style>
    .m-input {
      width: 100%;
      padding: 6px 4px;
      background: rgb(15 23 42 / 1);
      border: 1px solid rgb(71 85 105 / 1);
      color: white;
      border-radius: 4px;
      text-align: center;
      font-size: 13px;
      font-family: ui-monospace, SFMono-Regular, monospace;
    }
    .m-input:focus { border-color: #00bcd4; outline: none; }
    .p-cell {
      padding: 4px;
      background: rgb(15 23 42 / 0.6);
      border-radius: 3px;
      text-align: center;
      color: rgb(228 240 255 / 1);
      font-family: ui-monospace, SFMono-Regular, monospace;
    }
    .phase-btn, .rank-btn {
      background: rgb(51 65 85 / 1);
      border: 1px solid rgb(71 85 105 / 1);
      color: rgb(241 245 249 / 1);
    }
    .phase-btn:hover, .rank-btn:hover {
      background: rgb(0 188 212 / 0.3);
    }
    .phase-btn.active {
      background: rgb(0 188 212 / 0.3);
      border-color: rgb(0 188 212 / 1);
      color: rgb(241 245 249 / 1);
    }
    .rank-btn.active {
      background: rgb(245 158 11 / 0.3);
      border-color: rgb(245 158 11 / 1);
      color: rgb(241 245 249 / 1);
    }
    .sigma-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid rgb(71 85 105 / 0.3);
    }
    .sigma-row:last-child { border-bottom: none; }
    .sigma-bar {
      height: 6px;
      border-radius: 3px;
      transition: width 0.2s;
    }
    .sigma-row.dropped .sigma-bar { opacity: 0.25; }
    .sigma-row.dropped .sigma-value { color: rgb(100 116 139 / 1); text-decoration: line-through; }
  </style>

  <script>
    import { SVDScene } from '@/lib/math/linalg/SVDScene';
    import { SVD_PRESETS } from '@/lib/math/linalg/svdPresets';
    import { formatNumber } from '@/lib/math/linalg/MatrixMath';

    document.addEventListener('DOMContentLoaded', () => {
      // 3×3 matrix input grid (NOT symmetric — SVD works on any matrix)
      const grid = document.getElementById('matrix-grid')!;
      const cellInputs: HTMLInputElement[][] = [];
      for (let i = 0; i < 3; i++) {
        const row: HTMLInputElement[] = [];
        for (let j = 0; j < 3; j++) {
          const input = document.createElement('input');
          input.type = 'number';
          input.step = '0.1';
          input.className = 'm-input';
          input.value = i === j ? '1' : '0';
          input.dataset.row = String(i);
          input.dataset.col = String(j);
          input.addEventListener('input', () => {
            const v = parseFloat(input.value);
            if (Number.isNaN(v)) return;
            scene.setMatrixCell(i, j, v);
          });
          grid.appendChild(input);
          row.push(input);
        }
        cellInputs.push(row);
      }

      function syncToGrid(m: number[][]) {
        for (let i = 0; i < 3; i++) {
          for (let j = 0; j < 3; j++) {
            cellInputs[i][j].value = formatNumber(m[i][j], 4);
          }
        }
      }

      // Sigma bars
      const sigmaList = document.getElementById('sigma-list')!;
      const sigmaRows: { row: HTMLDivElement; bar: HTMLDivElement; value: HTMLSpanElement }[] = [];
      const sigmaColors = ['#ff80ab', '#b9f6ca', '#80d8ff'];
      for (let i = 0; i < 3; i++) {
        const row = document.createElement('div');
        row.className = 'sigma-row';
        const label = document.createElement('span');
        label.className = 'text-base-400';
        label.innerHTML = `σ<sub>${i + 1}</sub>`;
        const barWrap = document.createElement('div');
        const bar = document.createElement('div');
        bar.className = 'sigma-bar';
        bar.style.background = sigmaColors[i];
        bar.style.width = '50%';
        barWrap.appendChild(bar);
        const value = document.createElement('span');
        value.className = 'sigma-value text-base-50 font-bold tabular-nums';
        value.textContent = '1';
        row.appendChild(label);
        row.appendChild(barWrap);
        row.appendChild(value);
        sigmaList.appendChild(row);
        sigmaRows.push({ row, bar, value });
      }

      // U, V grids (readonly)
      const buildReadonlyGrid = (id: string) => {
        const container = document.getElementById(id)!;
        const cells: HTMLDivElement[][] = [];
        for (let i = 0; i < 3; i++) {
          const row: HTMLDivElement[] = [];
          for (let j = 0; j < 3; j++) {
            const cell = document.createElement('div');
            cell.className = 'p-cell';
            cell.textContent = i === j ? '1' : '0';
            container.appendChild(cell);
            row.push(cell);
          }
          cells.push(row);
        }
        return cells;
      };
      const uCells = buildReadonlyGrid('u-grid');
      const vCells = buildReadonlyGrid('v-grid');

      const rankVal = document.getElementById('rank-val')!;
      const condVal = document.getElementById('cond-val')!;
      const condHint = document.getElementById('cond-hint')!;
      const presetHint = document.getElementById('preset-hint')!;
      const phaseHint = document.getElementById('phase-hint')!;

      const PHASE_HINTS = [
        '單位球：起點。三條彩色箭頭是 V 的欄向量（輸入主方向）。',
        '套用 Vᵀ：球還是球（旋轉不改形狀），但箭頭轉到 X/Y/Z 軸對齊。',
        '套用 Σ：球變橢球！沿 X/Y/Z 各被拉 σ₁, σ₂, σ₃ 倍。',
        '套用 U：橢球旋轉到最終位置。三條箭頭 = σᵢ·uᵢ（最終主軸）。',
      ];

      let currentRank: 1 | 2 | 3 = 3;

      const scene = new SVDScene({
        containerId: 'scene-container',
        onUpdate: ({ decomposition, conditionNumber, rankEffective, phase, rank }) => {
          const { U, sigma, V } = decomposition;
          const maxSigma = Math.max(...sigma, 0.001);
          sigma.forEach((s, i) => {
            const r = sigmaRows[i];
            r.value.textContent = formatNumber(s, 4);
            r.bar.style.width = `${(s / maxSigma * 100).toFixed(0)}%`;
            if (i + 1 > rank) {
              r.row.classList.add('dropped');
            } else {
              r.row.classList.remove('dropped');
            }
          });

          for (let i = 0; i < 3; i++) {
            for (let j = 0; j < 3; j++) {
              uCells[i][j].textContent = formatNumber(U[i][j], 3);
              vCells[i][j].textContent = formatNumber(V[i][j], 3);
            }
          }

          rankVal.textContent = String(rankEffective);
          rankVal.className = rankEffective < 3 ? 'text-accent-yellow font-bold' : 'text-base-50 font-bold';
          if (Number.isFinite(conditionNumber)) {
            condVal.textContent = formatNumber(conditionNumber, 2);
            condVal.className = conditionNumber > 100 ? 'text-accent-red font-bold' : 'text-base-50 font-bold';
            condHint.textContent = conditionNumber > 1000 ? '⚠️ 條件數極高 — 求逆數值上會嚴重放大誤差。' :
                                  conditionNumber > 100 ? '⚠️ 條件數較高 — 計算需特別小心。' :
                                  conditionNumber < 10 ? '✅ 條件數正常，數值穩定。' :
                                  '⚡ 條件數中等。';
          } else {
            condVal.textContent = '∞';
            condVal.className = 'text-accent-red font-bold';
            condHint.textContent = '⚠️ 矩陣奇異（σ_min = 0），無法計算條件數。';
          }

          phaseHint.textContent = PHASE_HINTS[phase];
        },
      });

      // Vector inputs handled by matrix grid only
      // Preset buttons
      document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.preset!;
          const p = SVD_PRESETS.find((x) => x.id === id);
          if (!p) return;
          scene.setMatrix(p.matrix);
          syncToGrid(p.matrix);
          presetHint.textContent = p.hint;
        });
      });

      // Phase buttons
      const phaseBtns = document.querySelectorAll<HTMLButtonElement>('[data-phase]');
      phaseBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          phaseBtns.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const p = parseInt(btn.dataset.phase!, 10) as 0 | 1 | 2 | 3;
          scene.setPhase(p);
        });
      });

      // Rank buttons
      const rankBtns = document.querySelectorAll<HTMLButtonElement>('[data-rank]');
      rankBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          rankBtns.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const k = parseInt(btn.dataset.rank!, 10) as 1 | 2 | 3;
          currentRank = k;
          scene.setRank(k);
        });
      });

      document.getElementById('reset-matrix')!.addEventListener('click', () => {
        const I = [[1, 0, 0], [0, 1, 0], [0, 0, 1]];
        scene.setMatrix(I);
        syncToGrid(I);
        presetHint.textContent = '已重設為單位矩陣。';
      });

      window.addEventListener('beforeunload', () => scene.destroy());
    });
  </script>
</BaseLayout>

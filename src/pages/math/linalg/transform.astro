---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PRESETS } from '@/lib/math/linalg/presets';
import katex from 'katex';
import 'katex/dist/katex.min.css';

const tex = (s: string, display = false) =>
  katex.renderToString(s, { displayMode: display, throwOnError: false, output: 'html' });
---
<BaseLayout
  currentPage="math"
  title="4×4 矩陣變換視覺化"
  description="把矩陣當作動詞 — 即時改變每個分量，看立方體與向量如何被拉伸、旋轉、平移。"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-16">
    <a href="/math/linalg/" class="text-accent-blue hover:underline text-sm">← 回線性代數專區</a>

    <header class="mt-4 mb-6 text-center">
      <p class="text-base-400 text-sm tracking-widest uppercase mb-2">Chapter 1 · 直覺基礎</p>
      <h1 class="text-3xl md:text-4xl font-bold text-base-50 mb-2">🧊 4×4 矩陣變換</h1>
      <p class="text-base-400 max-w-2xl mx-auto">「矩陣不是一堆數字 — 它是一個動作。」拖滑鼠繞圈看立方體，動手改數字試試。</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- 左側：3D 畫布 -->
      <div class="lg:col-span-2">
        <div id="scene-container" class="rounded-lg border border-base-600 bg-base-900 overflow-hidden shadow-lg" style="height: 60vh; min-height: 420px;"></div>

        <div class="mt-3 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 text-xs">
          <div class="flex items-center gap-2 px-3 py-2 rounded bg-base-800 border border-base-600">
            <span class="w-3 h-3 rounded" style="background:#ff5252"></span> X 軸
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded bg-base-800 border border-base-600">
            <span class="w-3 h-3 rounded" style="background:#69f0ae"></span> Y 軸
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded bg-base-800 border border-base-600">
            <span class="w-3 h-3 rounded" style="background:#448aff"></span> Z 軸
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded bg-base-800 border border-base-600">
            <span class="w-3 h-3 rounded" style="background:#ff9800"></span> 原向量
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded bg-base-800 border border-base-600">
            <span class="w-3 h-3 rounded" style="background:#00e5ff"></span> 變換後
          </div>
        </div>
      </div>

      <!-- 右側：控制面板 -->
      <div class="space-y-4">
        <!-- Preset 按鈕 -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-blue text-sm">
            🎯 預設變換
          </div>
          <div class="p-3 grid grid-cols-2 gap-2">
            {PRESETS.map((preset) => (
              <button
                data-preset={preset.id}
                class="px-2 py-2 text-xs rounded bg-base-700 hover:bg-accent-blue/30 border border-base-600 text-base-100 transition text-left"
                title={preset.hint}
              >
                {preset.label}
              </button>
            ))}
          </div>
          <div class="px-4 py-2 bg-base-900/60 border-t border-base-600">
            <p id="preset-hint" class="text-xs text-base-400 italic min-h-[2.5em]">點上面任一按鈕，或自己改下面的數字。</p>
          </div>
        </div>

        <!-- 矩陣輸入 -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-cyan text-sm flex justify-between items-center">
            <span>🔲 變換矩陣 M</span>
            <button id="reset-matrix" class="px-2 py-0.5 text-xs rounded bg-base-700 hover:bg-base-600 border border-base-600">重設</button>
          </div>
          <div class="p-3">
            <div id="matrix-grid" class="grid grid-cols-4 gap-1"></div>
            <p class="mt-2 text-xs text-base-400">右邊一欄 (M03, M13, M23) 是平移；最後一列鎖住，動了會破壞齊次座標。</p>
          </div>
        </div>

        <!-- 向量輸入 -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-yellow text-sm">
            🏹 輸入向量 v
          </div>
          <div class="p-3 grid grid-cols-4 gap-2">
            <div>
              <div class="text-xs text-base-400 text-center mb-1">X</div>
              <input type="number" id="vec-x" value="1" step="0.5" class="vec-input">
            </div>
            <div>
              <div class="text-xs text-base-400 text-center mb-1">Y</div>
              <input type="number" id="vec-y" value="1" step="0.5" class="vec-input">
            </div>
            <div>
              <div class="text-xs text-base-400 text-center mb-1">Z</div>
              <input type="number" id="vec-z" value="1" step="0.5" class="vec-input">
            </div>
            <div>
              <div class="text-xs text-base-400 text-center mb-1">W</div>
              <input type="number" value="1" readonly class="vec-input text-base-500 bg-base-900">
            </div>
          </div>
        </div>

        <!-- 計算結果 -->
        <div class="rounded-lg border border-accent-cyan/40 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-accent-cyan/10 border-b border-accent-cyan/40 font-bold text-accent-cyan text-sm flex items-center gap-2">
            <span>🧮</span>
            <span set:html={tex('M \\cdot v \\;=')} />
          </div>
          <div class="p-4 font-mono">
            <p id="result-vec" class="text-xl text-accent-cyan mb-3">[ 1, 1, 1 ]</p>
            <div class="text-xs text-base-300 space-y-0.5" id="result-expand"></div>
            <hr class="border-base-600 my-3">
            <div class="flex justify-between items-center text-sm">
              <span class="text-base-400" set:html={'行列式 ' + tex('\\det(M) \\;=')}></span>
              <span id="det-value" class="text-base-50 font-bold">1</span>
            </div>
            <p id="det-hint" class="text-xs text-base-400 mt-1 min-h-[1.2em]"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- 教學內容 -->
    <section class="mt-12 max-w-3xl mx-auto prose-content">
      <h2 class="text-2xl font-bold text-base-50 mb-4">📖 為什麼要先學這個？</h2>

      <div class="space-y-4 text-base-300 leading-relaxed">
        <p>線性代數最核心的觀念是：<strong class="text-base-50">矩陣不是一堆死數字，而是一個「動作」</strong>。它把一個向量送進去，吐出另一個向量。從這個角度看，所有線性代數的招式（投影、對角化、SVD ...）都是在問同一件事：<em class="text-accent-cyan">這個動作到底在做什麼？</em></p>

        <p>4×4 是 3D 圖學的標準尺寸。為什麼不是 3×3？因為 3×3 矩陣只能做<strong class="text-base-50">旋轉、縮放、剪切</strong>這些「動原點不變」的變換，做不了<strong class="text-base-50">平移</strong>。把座標多加一個 <span set:html={tex('w=1')} /> 變成 4 維（叫做齊次座標），平移就能塞進矩陣最右邊那一欄裡。代價就是多了一列 <span set:html={tex('[\\,0,\\,0,\\,0,\\,1\\,]')} />，這列除非要做透視投影，否則永遠是這個樣子。</p>

        <div class="my-6 flex justify-center" set:html={tex(`
          \\begin{bmatrix}
            x' \\\\\\\\ y' \\\\\\\\ z' \\\\\\\\ 1
          \\end{bmatrix} \\;=\\;
          \\begin{bmatrix}
            m_{00} & m_{01} & m_{02} & t_x \\\\\\\\
            m_{10} & m_{11} & m_{12} & t_y \\\\\\\\
            m_{20} & m_{21} & m_{22} & t_z \\\\\\\\
            0 & 0 & 0 & 1
          \\end{bmatrix}
          \\begin{bmatrix}
            x \\\\\\\\ y \\\\\\\\ z \\\\\\\\ 1
          \\end{bmatrix}
        `, true)} />

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🎮 動手試試</h3>
        <ol class="list-decimal list-inside space-y-2 ml-2">
          <li>點 <strong class="text-accent-blue">縮放</strong> → 看立方體在 X 方向變寬、Y 方向被壓扁。注意對角線上的數字直接控制每個軸的縮放比例。</li>
          <li>點 <strong class="text-accent-blue">繞 Z 旋轉 45°</strong> → 立方體繞 Z 軸轉了。注意數字裡那些 <code class="text-accent-cyan">0.7071</code>，就是 cos45° 和 sin45°。</li>
          <li>點 <strong class="text-accent-blue">鏡射</strong> → 立方體翻面了。看下面的<strong class="text-base-50">行列式變成 −1</strong>，這就是「翻過去」的數學記號。</li>
          <li>手動把 M[0][0] 改成 0 → 立方體被壓成一個平面。<strong class="text-base-50">行列式變成 0</strong>，代表這個矩陣把整個 3D 空間壓扁了，沒辦法還原。</li>
          <li>連續點不同的 preset → 你會發現變換是「取代」不是「累加」。如果想做組合，得自己把矩陣相乘（之後的章節會玩到）。</li>
        </ol>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">💡 行列式在說什麼</h3>
        <p>右下角那個 <span set:html={tex('\\det(M)')} /> 數字，其實是<strong class="text-base-50">「這個變換把單位立方體的體積放大幾倍」</strong>：</p>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><span set:html={tex('\\det = 1')} /> — 體積不變（旋轉、平移都是這樣）</li>
          <li><span set:html={tex('\\det = 2')} /> — 體積變兩倍（縮放、剪切會改變）</li>
          <li><span set:html={tex('\\det < 0')} /> — 翻面了（鏡射、反射）</li>
          <li><span set:html={tex('\\det = 0')} /> — 壓扁了。這個矩陣<strong class="text-base-50">不可逆</strong>，因為你沒辦法把一個平面「還原回」一個立方體。</li>
        </ul>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🚀 下一步</h3>
        <p>當你能直觀感受「矩陣就是動作」之後，接下來幾頁會教你回答這些問題：</p>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><a href="/math/linalg/composition" class="text-accent-blue hover:underline">矩陣組合</a>：兩個動作疊起來會發生什麼？為什麼順序很重要？</li>
          <li><a href="/math/linalg/projection" class="text-accent-blue hover:underline">投影</a>：把高維資料壓到一條線或一個平面 — 怎麼壓最不失真？</li>
          <li><a href="/math/linalg/change-of-basis" class="text-accent-blue hover:underline">換基底</a>：同一個向量在不同座標系裡怎麼變？這是圖學、PCA、Fourier 的共同骨幹。</li>
          <li><a href="/math/linalg/eigen" class="text-accent-blue hover:underline">特徵向量</a>：有沒有哪些方向「被矩陣作用後仍是原方向」？PageRank 與 PCA 的核心。</li>
          <li><a href="/math/linalg/svd" class="text-accent-blue hover:underline">SVD</a>：任何矩陣都能拆成「旋轉 → 拉伸 → 旋轉」三步 — CS 線代的最高峰。</li>
        </ul>
      </div>
    </section>
  </div>

  <style>
    .vec-input,
    .m-input {
      width: 100%;
      padding: 6px 4px;
      background: rgb(15 23 42 / 1);
      border: 1px solid rgb(71 85 105 / 1);
      color: white;
      border-radius: 4px;
      text-align: center;
      font-size: 13px;
      font-family: ui-monospace, SFMono-Regular, monospace;
    }
    .vec-input:focus,
    .m-input:focus {
      border-color: #00bcd4;
      outline: none;
    }
    .m-input.locked {
      background: rgb(15 23 42 / 0.6);
      color: rgb(100 116 139 / 1);
    }
  </style>

  <script>
    import { MatrixScene3D } from '@/lib/math/linalg/MatrixScene3D';
    import { PRESETS } from '@/lib/math/linalg/presets';
    import { identity4, formatNumber, type Matrix4 } from '@/lib/math/linalg/MatrixMath';

    document.addEventListener('DOMContentLoaded', () => {
      // Build the 4×4 input grid
      const grid = document.getElementById('matrix-grid')!;
      const cellInputs: HTMLInputElement[][] = [];
      for (let i = 0; i < 4; i++) {
        const row: HTMLInputElement[] = [];
        for (let j = 0; j < 4; j++) {
          const input = document.createElement('input');
          input.type = 'number';
          input.step = '0.1';
          input.className = i === 3 ? 'm-input locked' : 'm-input';
          input.value = i === j ? '1' : '0';
          if (i === 3) input.readOnly = true;
          input.dataset.row = String(i);
          input.dataset.col = String(j);
          input.addEventListener('input', () => {
            if (i === 3) return; // last row is locked
            const v = parseFloat(input.value);
            if (!Number.isNaN(v)) scene.setMatrixCell(i, j, v);
          });
          grid.appendChild(input);
          row.push(input);
        }
        cellInputs.push(row);
      }

      function syncMatrixToGrid(m: Matrix4) {
        for (let i = 0; i < 4; i++) {
          for (let j = 0; j < 4; j++) {
            cellInputs[i][j].value = formatNumber(m[i][j], 4);
          }
        }
      }

      // Result display
      const resultVec = document.getElementById('result-vec')!;
      const resultExpand = document.getElementById('result-expand')!;
      const detValue = document.getElementById('det-value')!;
      const detHint = document.getElementById('det-hint')!;
      const presetHint = document.getElementById('preset-hint')!;

      function renderExpansion(m: Matrix4, v: [number, number, number]) {
        const rowLabels = ["x'", "y'", "z'"];
        const lines = [];
        for (let i = 0; i < 3; i++) {
          const terms = [
            `${formatNumber(m[i][0])}·x`,
            `${formatNumber(m[i][1])}·y`,
            `${formatNumber(m[i][2])}·z`,
            formatNumber(m[i][3]),
          ];
          lines.push(`${rowLabels[i]} = ${terms.join(' + ').replace(/\+ -/g, '− ')}`);
        }
        resultExpand.innerHTML = lines.map((l) => `<div>${l}</div>`).join('');
      }

      function describeDet(det: number): string {
        const abs = Math.abs(det);
        if (abs < 1e-9) return '⚠️ 矩陣不可逆 — 把空間壓扁了（降維）。';
        if (det < 0) return `🔄 翻面了（鏡射 / 反射）— 體積變 ${abs.toFixed(2)} 倍。`;
        if (Math.abs(det - 1) < 1e-9) return '✅ 體積保持不變（旋轉或平移）。';
        return `📏 體積放大 ${det.toFixed(2)} 倍。`;
      }

      // Scene
      const scene = new MatrixScene3D({
        containerId: 'scene-container',
        onUpdate: ({ result, determinant, matrix, vector }) => {
          const w = result[3] === 0 ? 1 : result[3];
          resultVec.textContent = `[ ${formatNumber(result[0]/w)}, ${formatNumber(result[1]/w)}, ${formatNumber(result[2]/w)} ]`;
          renderExpansion(matrix, vector);
          detValue.textContent = formatNumber(determinant, 3);
          detValue.className = determinant < -1e-9 ? 'text-accent-red font-bold' :
                               Math.abs(determinant) < 1e-9 ? 'text-accent-yellow font-bold' :
                               'text-base-50 font-bold';
          detHint.textContent = describeDet(determinant);
        },
      });

      // Vector inputs
      const vx = document.getElementById('vec-x') as HTMLInputElement;
      const vy = document.getElementById('vec-y') as HTMLInputElement;
      const vz = document.getElementById('vec-z') as HTMLInputElement;
      [vx, vy, vz].forEach((el) => {
        el.addEventListener('input', () => {
          scene.setVector([
            parseFloat(vx.value) || 0,
            parseFloat(vy.value) || 0,
            parseFloat(vz.value) || 0,
          ]);
        });
      });

      // Preset buttons
      document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.preset;
          const preset = PRESETS.find((p) => p.id === id);
          if (!preset) return;
          scene.setMatrix(preset.matrix);
          syncMatrixToGrid(preset.matrix);
          presetHint.textContent = preset.hint;
        });
      });

      // Reset button
      document.getElementById('reset-matrix')!.addEventListener('click', () => {
        const id = identity4();
        scene.setMatrix(id);
        syncMatrixToGrid(id);
        presetHint.textContent = '已重設為單位矩陣 — 什麼都不變。';
      });

      // Cleanup on navigation
      window.addEventListener('beforeunload', () => scene.destroy());
    });
  </script>
</BaseLayout>

---
import MathLessonLayout from '@/layouts/MathLessonLayout.astro';
import katex from 'katex';
import 'katex/dist/katex.min.css';
import '@/styles/probstat.css';

const tex = (s: string, display = false) =>
  katex.renderToString(s, { displayMode: display, throwOnError: false, output: 'html' });
---
<MathLessonLayout
  section="probstat"
  slug="lln-clt"
  seoTitle="大數法則 與 中央極限定理 · 兩個機率最重要的定理"
  seoDescription="LLN：抽越多次、平均越接近真值。CLT：那個收斂的形狀本身是常態。兩個都動手看一次。"
>
  <p slot="tagline" class="text-base-400 max-w-2xl mx-auto">兩個定理回答兩個問題：「抽夠多次平均會收斂嗎？」「收斂得多快、長什麼樣？」</p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Canvas -->
      <div class="lg:col-span-2">
        <canvas id="llnclt-canvas" class="block w-full rounded-lg border border-base-600 bg-base-900 shadow-lg" style="height: 70vh; min-height: 520px;"></canvas>
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          <span class="ps-chip"><span class="dot" style="background: rgba(38,139,210,0.95)"></span>來源分布</span>
          <span class="ps-chip"><span class="dot" style="background: rgba(244,162,97,0.85)"></span>真實均值 μ</span>
          <span class="ps-chip"><span class="dot" style="background: rgba(133,153,0,0.95)"></span>樣本累積 / 直方圖</span>
          <span class="ps-chip"><span class="dot" style="background: rgba(220,50,47,0.95)"></span>理論常態 (CLT)</span>
        </div>
      </div>

      <!-- Controls -->
      <div class="space-y-4">
        <!-- Mode -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-blue text-sm">
            🔁 模式
          </div>
          <div class="p-3 grid grid-cols-1 gap-2" id="mode-list">
            <button data-mode="lln" class="ps-btn text-left active">大數法則 (LLN) · 追蹤累計均值</button>
            <button data-mode="clt" class="ps-btn text-left">中央極限 (CLT) · 樣本均值的分布</button>
          </div>
        </div>

        <!-- Source -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-cyan text-sm">
            🦒 來源分布
          </div>
          <div class="p-3 grid grid-cols-1 gap-2" id="source-list">
            <button data-source="uniform" class="ps-btn text-left active">U(0, 1) · 均勻</button>
            <button data-source="exponential" class="ps-btn text-left">Exp(1) · 右偏</button>
            <button data-source="dice2" class="ps-btn text-left">兩骰加總 · 離散</button>
            <button data-source="bimodal" class="ps-btn text-left">雙峰混合常態</button>
          </div>
        </div>

        <!-- n (only for CLT) -->
        <div id="n-block" class="rounded-lg border border-base-600 bg-base-800 overflow-hidden hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 font-bold text-accent-yellow text-sm flex justify-between">
            <span set:html={tex('n')} /> · 每組樣本大小
            <span id="n-ro" class="text-base-50 font-mono">30</span>
          </div>
          <div class="p-3"><input id="n-slider" type="range" class="ps-slider" min="2" max="200" step="1" value="30"></div>
        </div>

        <!-- Stats -->
        <div class="rounded-lg border border-accent-cyan/40 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-accent-cyan/10 border-b border-accent-cyan/40 font-bold text-accent-cyan text-sm">
            🧮 即時統計
          </div>
          <div class="p-4 space-y-2 text-sm font-mono">
            <div class="flex justify-between"><span class="text-base-400" id="stat-l1-label">已抽次數</span><span id="stat-l1" class="ps-readout accent-cyan w-28">—</span></div>
            <div class="flex justify-between"><span class="text-base-400" id="stat-l2-label">累計均值</span><span id="stat-l2" class="ps-readout accent-yellow w-28">—</span></div>
            <div class="flex justify-between"><span class="text-base-400">真實均值 μ</span><span id="stat-mu" class="ps-readout accent-magenta w-28">—</span></div>
          </div>
        </div>

        <!-- Run / reset -->
        <div class="grid grid-cols-2 gap-2">
          <button id="run-btn" class="ps-btn primary">▶ 開始</button>
          <button id="reset-btn" class="ps-btn">↻ 重設</button>
        </div>
      </div>
    </div>

    <!-- Teaching -->
    <section class="mt-12 max-w-3xl mx-auto prose-content">
      <h2 class="text-2xl font-bold text-base-50 mb-4">📖 兩個定理，一個故事</h2>

      <div class="space-y-4 text-base-300 leading-relaxed">
        <p><strong class="text-base-50">大數法則（LLN, Law of Large Numbers）</strong>說：當你不斷從同一個分布抽樣，累計樣本平均會收斂到母體均值。</p>

        <div class="my-4 flex justify-center" set:html={tex(`\\bar{X}_n = \\dfrac{1}{n}\\sum_{i=1}^{n} X_i \\;\\longrightarrow\\; \\mu \\quad \\text{as } n \\to \\infty`, true)} />

        <p>LLN 解釋的是「為什麼民調抽到夠多人就會準」、「為什麼擲一萬次骰子的平均一定接近 3.5」。<strong class="text-base-50">但 LLN 不告訴你收斂得多快，也不告訴你「離 μ 多遠的機率有多大」</strong>。</p>

        <p>那個答案來自 <strong class="text-base-50">中央極限定理（CLT, Central Limit Theorem）</strong>：</p>

        <div class="my-4 flex justify-center" set:html={tex(`\\sqrt{n}\\,(\\bar{X}_n - \\mu) \\;\\xrightarrow{d}\\; \\mathcal{N}(0, \\sigma^2)`, true)} />

        <p>白話：<strong class="text-base-50">把樣本均值的「偏差」放大 √n 倍，會收斂到一個常態分布</strong>。換成日常的講法：</p>

        <ul class="list-disc list-inside space-y-1 ml-2">
          <li>樣本均值 <span set:html={tex('\\bar{X}_n')} /> 的標準差是 <span set:html={tex('\\sigma / \\sqrt{n}')} />，跟 n 的平方根成反比</li>
          <li>不管來源分布長什麼樣（偏的、跳的、雙峰的），樣本均值的形狀都會變成鐘形</li>
          <li>樣本數加 4 倍，誤差只縮一半 — 這是「為什麼資料科學要的不是樣本多、是樣本大」</li>
        </ul>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🎮 動手試試</h3>
        <ol class="list-decimal list-inside space-y-2 ml-2">
          <li>切到 <strong class="text-accent-blue">LLN 模式</strong>、選 <strong>Exp(1)</strong>，按開始。注意累計均值線一開始上下亂跳，但很快貼到 μ=1 的橘色橫線。</li>
          <li>切到 <strong class="text-accent-blue">CLT 模式</strong>、選 <strong>雙峰混合常態</strong>，<span set:html={tex('n')} />=2 — 結果直方圖會明顯雙峰。把 <span set:html={tex('n')} /> 拉到 30 — 雙峰會消失、變鐘形。<strong class="text-base-50">這就是「中央極限」三個字最神奇的地方</strong>。</li>
          <li>同樣 CLT 模式、把 <span set:html={tex('n')} /> 從 10 拉到 40 — 看紅色理論曲線變窄到原來的一半（σ/√n 從 σ/√10 變成 σ/√40 ≈ σ/√10 ÷ 2）。</li>
          <li>切到 <strong>兩骰加總</strong>，<span set:html={tex('n')} />=1 — 樣本均值的分布就是「2 顆骰子加總」的三角形。<span set:html={tex('n')} />=10 — 變鐘形。CLT 不挑分布，只要有限變異數就行。</li>
        </ol>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">💡 為什麼這兩個定理這麼重要</h3>
        <p>它們幾乎是<strong class="text-base-50">所有統計推論的基礎</strong>：</p>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><strong class="text-base-50">信賴區間</strong> — 「樣本均值 ± 1.96 σ/√n 內包含真值的機率約 95%」就是 CLT 的直接應用</li>
          <li><strong class="text-base-50">A/B 測試的樣本量計算</strong> — 用 σ/√n 估算「要多大樣本才能偵測 X% 差異」</li>
          <li><strong class="text-base-50">蒙地卡羅模擬</strong> — 數值積分的誤差 = O(1/√n)，這個 √n 就是 CLT 給的</li>
          <li><strong class="text-base-50">機器學習的損失收斂</strong> — SGD 每步用一個 mini-batch 估計梯度，「梯度估計誤差 ~ 1/√batch_size」也是 CLT</li>
        </ul>

        <h3 class="text-xl font-bold text-base-50 mt-6 mb-3">🚀 之後會用到</h3>
        <ul class="list-disc list-inside space-y-1 ml-2">
          <li><strong class="text-base-50">貝氏定理</strong>（下一頁）— 也是另一種「資料越多越逼近真相」的數學描述</li>
          <li><strong class="text-base-50">最大似然估計</strong> — MLE 估計值在大樣本下會服從常態（asymptotic normality）</li>
          <li><strong class="text-base-50">熵與 KL</strong> — Cross-entropy loss 的收斂率也仰賴 CLT</li>
        </ul>
      </div>
    </section>


  <script>
    import { LLNCLTScene, type LLNCLTMode, type SourceKind, type LLNCLTState } from '@/lib/math/probstat/LLNCLTScene';
    import { fmt } from '@/lib/math/probstat/mathHelpers';

    const SOURCE_MU: Record<SourceKind, number> = {
      uniform: 0.5,
      exponential: 1,
      dice2: 7,
      bimodal: 0,
    };

    document.addEventListener('DOMContentLoaded', () => {
      const modeList = document.getElementById('mode-list')!;
      const sourceList = document.getElementById('source-list')!;
      const nBlock = document.getElementById('n-block')!;
      const nSlider = document.getElementById('n-slider') as HTMLInputElement;
      const nRo = document.getElementById('n-ro')!;
      const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
      const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
      const l1Label = document.getElementById('stat-l1-label')!;
      const l1 = document.getElementById('stat-l1')!;
      const l2Label = document.getElementById('stat-l2-label')!;
      const l2 = document.getElementById('stat-l2')!;
      const muEl = document.getElementById('stat-mu')!;

      function renderState(s: LLNCLTState) {
        modeList.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((b) => {
          b.classList.toggle('active', b.dataset.mode === s.mode);
        });
        sourceList.querySelectorAll<HTMLButtonElement>('[data-source]').forEach((b) => {
          b.classList.toggle('active', b.dataset.source === s.source);
        });
        nBlock.classList.toggle('hidden', s.mode === 'lln');
        nRo.textContent = String(s.n);
        muEl.textContent = fmt(SOURCE_MU[s.source], 3);
        runBtn.textContent = s.isRunning ? '⏸ 暫停' : '▶ 開始';
        runBtn.classList.toggle('active-yellow', s.isRunning);
        if (s.mode === 'lln') {
          l1Label.textContent = '已抽次數';
          l2Label.textContent = '累計均值';
          l1.textContent = s.currentN.toLocaleString('en-US');
          l2.textContent = Number.isFinite(s.currentMean) ? s.currentMean.toFixed(4) : '—';
        } else {
          l1Label.textContent = '已完成組數';
          l2Label.textContent = 'σ / √n';
          l1.textContent = s.numTrials.toLocaleString('en-US');
          // σ/√n requires source variance — compute on the spot
          const sigmaMap: Record<SourceKind, number> = {
            uniform: Math.sqrt(1 / 12),
            exponential: 1,
            dice2: Math.sqrt(35 / 6),
            bimodal: Math.sqrt(1.09),
          };
          l2.textContent = (sigmaMap[s.source] / Math.sqrt(s.n)).toFixed(4);
        }
      }

      const scene = new LLNCLTScene({ canvasId: 'llnclt-canvas', onUpdate: renderState });

      modeList.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((btn) => {
        btn.addEventListener('click', () => scene.setMode(btn.dataset.mode as LLNCLTMode));
      });
      sourceList.querySelectorAll<HTMLButtonElement>('[data-source]').forEach((btn) => {
        btn.addEventListener('click', () => scene.setSource(btn.dataset.source as SourceKind));
      });
      nSlider.addEventListener('input', () => scene.setN(parseInt(nSlider.value, 10)));
      runBtn.addEventListener('click', () => scene.toggleRun());
      resetBtn.addEventListener('click', () => scene.reset());

      window.addEventListener('beforeunload', () => scene.destroy());
    });
  </script>
</MathLessonLayout>

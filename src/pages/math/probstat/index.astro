---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/probstat.css';

const colorMap: Record<string, { bg: string; hover: string; border: string }> = {
  primary: { bg: 'bg-accent-blue', hover: 'hover:bg-accent-blue/80', border: 'border-accent-blue' },
  success: { bg: 'bg-accent-green', hover: 'hover:bg-accent-green/80', border: 'border-accent-green' },
  info: { bg: 'bg-accent-cyan', hover: 'hover:bg-accent-cyan/80', border: 'border-accent-cyan' },
  warning: { bg: 'bg-accent-yellow', hover: 'hover:bg-accent-yellow/80', border: 'border-accent-yellow' },
  danger: { bg: 'bg-accent-red', hover: 'hover:bg-accent-red/80', border: 'border-accent-red' },
};

interface Tool {
  title: string;
  description: string;
  href: string;
  color: string;
  ready: boolean;
  chapter: string;
}

const tools: Tool[] = [
  {
    title: '📦 機率分布動物園',
    description: '常態、二項、Poisson、指數、均勻 — 拉滑桿改參數，PMF / PDF 跟 CDF 即時跟著動。一頁看清「分布長什麼樣」。',
    href: '/math/probstat/distributions',
    color: 'primary',
    ready: true,
    chapter: 'Chapter 1 · 基礎',
  },
  {
    title: '🎯 大數法則與中央極限',
    description: '抽樣均值會收斂到母體均值（LLN），而且收斂的速度和形狀，本身又是常態分布（CLT）— 兩個 demo 同台演示。',
    href: '/math/probstat/lln-clt',
    color: 'primary',
    ready: true,
    chapter: 'Chapter 1 · 基礎',
  },
  {
    title: '🔮 貝氏定理',
    description: 'Beta–Binomial 共軛先驗：拉先驗、按按鈕加觀測，後驗即時更新。看「資料怎麼修正信念」。',
    href: '/math/probstat/bayes',
    color: 'success',
    ready: true,
    chapter: 'Chapter 2 · 推論',
  },
  {
    title: '📏 最大似然估計',
    description: '線性迴歸的「最小平方」其實是「假設誤差是常態」下的 MLE。拖資料點，看 NLL 等高線怎麼移動，最佳擬合線怎麼追上去。',
    href: '/math/probstat/mle',
    color: 'success',
    ready: true,
    chapter: 'Chapter 2 · 推論',
  },
  {
    title: '🚶 馬可夫鏈與 MCMC',
    description: 'Metropolis–Hastings 一步一步把點丟到目標分布上。可暫停、可加速 — 看「亂走也能畫出機率密度」。',
    href: '/math/probstat/markov',
    color: 'warning',
    ready: true,
    chapter: 'Chapter 3 · 模擬與資訊',
  },
  {
    title: '🔥 熵與 KL 散度',
    description: '熵是「平均驚訝度」、KL 是「用錯分布要多付的 bits」— 兩條分布並排可動，直接看 cross-entropy loss 在算什麼。',
    href: '/math/probstat/entropy',
    color: 'danger',
    ready: true,
    chapter: 'Chapter 3 · 模擬與資訊',
  },
];
---
<BaseLayout
  currentPage="math"
  title="機率統計視覺化"
  description="從分布到 MCMC — 6 頁互動式視覺化建立機率統計直覺。承接 linalg / calculus 的教學風格。"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-16">
    <header class="text-center mb-10">
      <p class="text-base-400 text-sm tracking-widest uppercase mb-2">機率統計專區</p>
      <h1 class="text-3xl md:text-4xl font-bold text-base-50 mb-3">機率統計 · 動手玩版本</h1>
      <p class="text-base-400 max-w-2xl mx-auto">
        從分布、抽樣到貝氏與資訊論 — 不背公式、不查表。每個概念都先動手丟一次，再上符號。
      </p>
    </header>

    <!-- ─────────── 熱身：擲骰子模擬器 ─────────── -->
    <section class="rounded-lg border border-accent-yellow/40 bg-base-800/60 p-6 mb-10">
      <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
        <h2 class="text-xl font-bold text-accent-yellow">🎲 熱身：擲骰子</h2>
        <p class="text-sm text-base-400">先看「丟越多次，經驗分布越貼近理論分布」這件事</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        <!-- Canvas -->
        <div class="lg:col-span-2">
          <div class="relative w-full rounded-md bg-base-900/60 border border-base-700" style="aspect-ratio: 16/9; min-height: 320px;">
            <canvas id="dice-canvas" class="absolute inset-0 w-full h-full"></canvas>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="ps-chip"><span class="dot" style="background: rgba(38,139,210,0.85)"></span>經驗相對次數</span>
            <span class="ps-chip"><span class="dot" style="background: rgba(220,50,47,0.85)"></span>理論機率</span>
            <span class="ps-chip"><span class="dot" style="background: rgba(244,162,97,0.95)"></span>剛擲到的點數</span>
          </div>
        </div>

        <!-- Controls -->
        <div class="space-y-4">
          <!-- Mode toggle -->
          <div>
            <p class="text-xs text-base-400 uppercase tracking-wider mb-2">模式</p>
            <div class="grid grid-cols-2 gap-2">
              <button id="dice-mode-1" class="ps-btn active" type="button">1 顆骰子</button>
              <button id="dice-mode-2" class="ps-btn" type="button">2 顆骰子加總</button>
            </div>
          </div>

          <!-- Counter -->
          <div>
            <p class="text-xs text-base-400 uppercase tracking-wider mb-1">已擲次數</p>
            <div class="ps-readout accent-cyan" style="font-size: 18px; padding: 10px;">
              <span id="dice-counter">0</span>
            </div>
          </div>

          <!-- Roll buttons -->
          <div>
            <p class="text-xs text-base-400 uppercase tracking-wider mb-2">手動擲</p>
            <div class="grid grid-cols-3 gap-2">
              <button class="ps-btn" data-roll="1" type="button">+1</button>
              <button class="ps-btn" data-roll="10" type="button">+10</button>
              <button class="ps-btn" data-roll="100" type="button">+100</button>
            </div>
          </div>

          <!-- Auto + reset -->
          <div>
            <p class="text-xs text-base-400 uppercase tracking-wider mb-2">自動 / 重設</p>
            <div class="grid grid-cols-2 gap-2">
              <button id="dice-auto" class="ps-btn primary" type="button">▶ 持續擲</button>
              <button id="dice-reset" class="ps-btn" type="button">↻ 重設</button>
            </div>
          </div>

          <!-- Theoretical toggle -->
          <label class="flex items-center gap-2 text-sm text-base-300 cursor-pointer select-none">
            <input id="dice-show-theo" type="checkbox" checked class="accent-accent-cyan" />
            顯示理論機率
          </label>
        </div>
      </div>

      <!-- Hint -->
      <div class="mt-5 grid md:grid-cols-2 gap-4 text-sm text-base-300 leading-relaxed">
        <div>
          <span class="text-accent-yellow font-semibold">🎯 看 1 顆骰子</span>：理論上每面 1/6（均勻分布）。
          剛開始擲幾下，柱狀圖會起伏亂跳；擲到幾千次，每根柱子都會壓到那條紅線上。
        </div>
        <div>
          <span class="text-accent-yellow font-semibold">📊 切到 2 顆骰子</span>：兩個均勻分布相加，結果是
          三角形。這就是中央極限定理的小型版本 — <strong class="text-base-50">獨立隨機變數相加，分布會往對稱、像山的形狀靠</strong>。
        </div>
      </div>
    </section>

    <!-- ─────────── 為什麼學 ─────────── -->
    <section class="rounded-lg border border-base-600 bg-base-800/60 p-6 mb-10">
      <h2 class="text-lg font-bold text-accent-blue mb-3">📍 為什麼學機率統計？</h2>
      <div class="grid md:grid-cols-2 gap-4 text-base-300 text-sm leading-relaxed">
        <div>
          <p class="mb-2"><span class="text-base-50 font-semibold">機器學習</span> — Cross-entropy loss、KL divergence 都直接出自資訊論</p>
          <p class="mb-2"><span class="text-base-50 font-semibold">A/B 測試</span> — 信賴區間、貝氏更新都是日常會用到的工具</p>
          <p><span class="text-base-50 font-semibold">強化學習</span> — MCMC、隨機過程是策略最佳化的基礎</p>
        </div>
        <div>
          <p class="mb-2"><span class="text-base-50 font-semibold">系統設計</span> — Queueing、Poisson 到達率、tail latency</p>
          <p class="mb-2"><span class="text-base-50 font-semibold">資安 / 密碼學</span> — 機率估計與隨機性是攻擊與防禦的核心</p>
          <p><span class="text-base-50 font-semibold">產品決策</span> — 期望值、效用函式、不確定性下的決策</p>
        </div>
      </div>
    </section>

    <!-- ─────────── 6 個內頁卡片 ─────────── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool) => {
        const colors = colorMap[tool.color];
        return (
          <div class={`flex flex-col rounded-lg border ${colors.border} bg-base-800 h-full`}>
            <div class="p-5 flex-1">
              <p class="text-xs text-base-400 mb-1">{tool.chapter}</p>
              <h5 class="text-lg font-semibold text-base-50 mb-2">{tool.title}</h5>
              <p class="text-base-400 text-sm">{tool.description}</p>
            </div>
            <div class="px-5 pb-5">
              {tool.ready ? (
                <a
                  href={tool.href}
                  class={`block text-center px-4 py-2 rounded ${colors.bg} ${colors.hover} text-base-50 font-medium transition`}
                >
                  開始學習 →
                </a>
              ) : (
                <span class="block text-center px-4 py-2 rounded border border-base-600 text-base-500 cursor-not-allowed">
                  籌備中
                </span>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <section class="mt-12 text-center text-base-400 text-sm">
      <p>對標 <a href="https://seeing-theory.brown.edu/" class="text-accent-blue hover:underline" target="_blank" rel="noopener">Seeing Theory · Brown University</a> — 看視覺化建直覺，回這裡動手玩。</p>
    </section>
  </div>

  <script>
    import { DiceScene, type DiceState } from '@/lib/math/probstat/DiceScene';

    document.addEventListener('DOMContentLoaded', () => {
      // Refs (declared BEFORE constructing the scene — TDZ trap, see calculus CLAUDE.md)
      const counterEl = document.getElementById('dice-counter') as HTMLSpanElement;
      const mode1Btn = document.getElementById('dice-mode-1') as HTMLButtonElement;
      const mode2Btn = document.getElementById('dice-mode-2') as HTMLButtonElement;
      const autoBtn = document.getElementById('dice-auto') as HTMLButtonElement;
      const resetBtn = document.getElementById('dice-reset') as HTMLButtonElement;
      const showTheoBox = document.getElementById('dice-show-theo') as HTMLInputElement;
      const rollBtns = document.querySelectorAll<HTMLButtonElement>('[data-roll]');

      function renderState(state: DiceState) {
        counterEl.textContent = state.totalRolls.toLocaleString('en-US');
        mode1Btn.classList.toggle('active', state.mode === '1d6');
        mode2Btn.classList.toggle('active', state.mode === '2d6');
        autoBtn.textContent = state.isAutoRolling ? '⏸ 暫停' : '▶ 持續擲';
        autoBtn.classList.toggle('active-yellow', state.isAutoRolling);
      }

      const scene = new DiceScene({ canvasId: 'dice-canvas', onUpdate: renderState });

      mode1Btn.addEventListener('click', () => scene.setMode('1d6'));
      mode2Btn.addEventListener('click', () => scene.setMode('2d6'));
      autoBtn.addEventListener('click', () => scene.toggleAuto());
      resetBtn.addEventListener('click', () => scene.reset());
      showTheoBox.addEventListener('change', () => scene.setShowTheoretical(showTheoBox.checked));

      rollBtns.forEach((btn) => {
        const n = Number.parseInt(btn.dataset.roll ?? '1', 10);
        btn.addEventListener('click', () => scene.roll(n));
      });
    });
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout currentPage="math"
  title="數學計算工具 (GCD/LCM/質數) | 挫屎勇的數學教室" 
  description="免費的線上數學計算工具，包含：質數檢查、質因數分解、最大公因數 (GCD) 計算、最小公倍數 (LCM) 計算。即時計算，支援大數運算。"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <h1 class="text-center text-3xl font-bold text-base-50 mb-6">🧮 數學計算工具</h1>
    
    <!-- 質數檢查 -->
    <section class="rounded-lg border border-base-600 bg-base-800 mb-4 overflow-hidden">
      <div class="px-4 py-3 bg-base-600/30 border-b border-base-600">
        <h2 class="text-lg font-semibold text-base-50">質數檢查</h2>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
          <div class="md:col-span-3">
            <label for="primeInput" class="block text-sm text-base-400 mb-1">輸入數字</label>
            <input type="text" id="primeInput" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="輸入一個整數">
          </div>
          <div>
            <button id="primeButton" class="w-full px-4 py-2 rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition">檢查</button>
          </div>
        </div>
        <div id="primeResult" class="mt-3"></div>
      </div>
    </section>

    <!-- 質因數分解 -->
    <section class="rounded-lg border border-base-600 bg-base-800 mb-4 overflow-hidden">
      <div class="px-4 py-3 bg-base-600/30 border-b border-base-600">
        <h2 class="text-lg font-semibold text-base-50">質因數分解</h2>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
          <div class="md:col-span-3">
            <label for="factorInput" class="block text-sm text-base-400 mb-1">輸入數字</label>
            <input type="text" id="factorInput" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="輸入一個大於 1 的整數">
          </div>
          <div>
            <button id="factorButton" class="w-full px-4 py-2 rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition">分解</button>
          </div>
        </div>
        <div id="factorResult" class="mt-3"></div>
      </div>
    </section>

    <!-- 最大公因數 -->
    <section class="rounded-lg border border-base-600 bg-base-800 mb-4 overflow-hidden">
      <div class="px-4 py-3 bg-base-600/30 border-b border-base-600">
        <h2 class="text-lg font-semibold text-base-50">最大公因數 (GCD)</h2>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
          <div>
            <label for="gcdInput1" class="block text-sm text-base-400 mb-1">第一個數字</label>
            <input type="text" id="gcdInput1" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="整數">
          </div>
          <div>
            <label for="gcdInput2" class="block text-sm text-base-400 mb-1">第二個數字</label>
            <input type="text" id="gcdInput2" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="整數">
          </div>
          <div>
            <button id="gcdButton" class="w-full px-4 py-2 rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition">計算 GCD</button>
          </div>
        </div>
        <div id="gcdResult" class="mt-3"></div>
      </div>
    </section>

    <!-- 最小公倍數 -->
    <section class="rounded-lg border border-base-600 bg-base-800 mb-4 overflow-hidden">
      <div class="px-4 py-3 bg-base-600/30 border-b border-base-600">
        <h2 class="text-lg font-semibold text-base-50">最小公倍數 (LCM)</h2>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
          <div>
            <label for="lcmInput1" class="block text-sm text-base-400 mb-1">第一個數字</label>
            <input type="text" id="lcmInput1" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="整數">
          </div>
          <div>
            <label for="lcmInput2" class="block text-sm text-base-400 mb-1">第二個數字</label>
            <input type="text" id="lcmInput2" class="w-full px-3 py-2 bg-base-900 border border-base-600 rounded text-base-50 focus:border-accent-blue focus:outline-none" placeholder="整數">
          </div>
          <div>
            <button id="lcmButton" class="w-full px-4 py-2 rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition">計算 LCM</button>
          </div>
        </div>
        <div id="lcmResult" class="mt-3"></div>
      </div>
    </section>

    <div class="text-center mt-6">
      <a href="/math/" class="px-4 py-2 rounded border border-base-600 text-base-400 hover:bg-base-600 transition">← 返回數學工具</a>
    </div>
  </div>
</BaseLayout>

<script>
  // === 工具函數 ===
  function parseBigInt(value: string): bigint | null {
    try {
      const trimmed = value.trim();
      if (!/^-?\d+$/.test(trimmed)) return null;
      return BigInt(trimmed);
    } catch {
      return null;
    }
  }

  function showResult(elementId: string, message: string, isError = false) {
    const el = document.getElementById(elementId);
    if (el) {
      const bgClass = isError ? 'bg-accent-red/20 border-accent-red text-accent-red' : 'bg-accent-green/20 border-accent-green text-accent-green';
      el.innerHTML = `<div class="p-3 rounded border ${bgClass}">${message}</div>`;
    }
  }

  function appendResult(elementId: string, message: string) {
    const el = document.getElementById(elementId);
    if (el) {
      el.innerHTML += `<div class="text-sm text-base-600">${message}</div>`;
    }
  }

  // === 質數相關 ===
  let primes: bigint[] = [2n, 3n, 5n, 7n, 11n, 13n];

  // Integer sqrt via Newton's method. Math.sqrt(Number(n)) loses precision
  // when n exceeds Number.MAX_SAFE_INTEGER (2^53), which made the original
  // sqrt cutoff unsafe for very large primes (could return wrong sqrt,
  // either missing a factor or stopping search too early).
  function bigintSqrt(n: bigint): bigint {
    if (n < 0n) throw new Error('bigintSqrt of negative');
    if (n < 2n) return n;
    let x = n;
    let y = (x + 1n) / 2n;
    while (y < x) {
      x = y;
      y = (x + n / x) / 2n;
    }
    return x;
  }

  function addNewPrime(): bigint {
    let candidate = primes[primes.length - 1] + 2n;
    while (!isPrimeQuick(candidate)) {
      candidate += 2n;
    }
    primes.push(candidate);
    return candidate;
  }

  function isPrimeQuick(num: bigint): boolean {
    if (num <= 1n) return false;
    if (num <= 3n) return true;
    if (num % 2n === 0n) return false;

    const sqrtNum = bigintSqrt(num);
    for (const p of primes) {
      if (p > sqrtNum) return true;
      if (num % p === 0n) return false;
    }
    return true;
  }

  function isPrime(num: bigint): boolean {
    if (num <= 1n) return false;
    if (num <= 3n) return true;
    if (num % 2n === 0n) return false;

    const sqrtNum = bigintSqrt(num);

    for (const p of primes) {
      if (p > sqrtNum) return true;
      if (num % p === 0n) return false;
    }

    let p = addNewPrime();
    while (p <= sqrtNum) {
      if (num % p === 0n) return false;
      p = addNewPrime();
    }
    return true;
  }

  // === 質數檢查 ===
  function checkPrime() {
    const input = (document.getElementById('primeInput') as HTMLInputElement).value;
    const num = parseBigInt(input);

    if (num === null) {
      showResult('primeResult', '請輸入有效的整數', true);
      return;
    }

    if (isPrime(num)) {
      showResult('primeResult', `${num} 是質數 ✓`);
    } else {
      showResult('primeResult', `${num} 不是質數 ✗`);
    }
  }

  // === 質因數分解 ===
  function factorize() {
    const input = (document.getElementById('factorInput') as HTMLInputElement).value;
    let num = parseBigInt(input);

    if (num === null || num <= 1n) {
      showResult('factorResult', '請輸入大於 1 的整數', true);
      return;
    }

    const factors: bigint[] = [];
    const original = num;

    while (num % 2n === 0n) {
      factors.push(2n);
      num /= 2n;
    }

    let divisor = 3n;
    while (divisor * divisor <= num) {
      while (num % divisor === 0n) {
        factors.push(divisor);
        num /= divisor;
      }
      divisor += 2n;
    }

    if (num > 1n) {
      factors.push(num);
    }

    if (factors.length === 1) {
      showResult('factorResult', `${original} 是質數`);
    } else {
      showResult('factorResult', `${original} = ${factors.join(' × ')}`);
    }
  }

  // === GCD / LCM ===
  function gcd(a: bigint, b: bigint): bigint {
    a = a < 0n ? -a : a;
    b = b < 0n ? -b : b;
    return b === 0n ? a : gcd(b, a % b);
  }

  function lcm(a: bigint, b: bigint): bigint {
    return (a * b) / gcd(a, b);
  }

  function calculateGCD() {
    const input1 = (document.getElementById('gcdInput1') as HTMLInputElement).value;
    const input2 = (document.getElementById('gcdInput2') as HTMLInputElement).value;
    const num1 = parseBigInt(input1);
    const num2 = parseBigInt(input2);

    if (num1 === null || num2 === null || num1 <= 0n || num2 <= 0n) {
      showResult('gcdResult', '請輸入兩個大於 0 的整數', true);
      return;
    }

    const result = gcd(num1, num2);
    showResult('gcdResult', `GCD(${num1}, ${num2}) = ${result}`);
  }

  function calculateLCM() {
    const input1 = (document.getElementById('lcmInput1') as HTMLInputElement).value;
    const input2 = (document.getElementById('lcmInput2') as HTMLInputElement).value;
    const num1 = parseBigInt(input1);
    const num2 = parseBigInt(input2);

    if (num1 === null || num2 === null || num1 <= 0n || num2 <= 0n) {
      showResult('lcmResult', '請輸入兩個大於 0 的整數', true);
      return;
    }

    const result = lcm(num1, num2);
    showResult('lcmResult', `LCM(${num1}, ${num2}) = ${result}`);
  }

  // === 事件綁定 ===
  document.getElementById('primeButton')?.addEventListener('click', checkPrime);
  document.getElementById('factorButton')?.addEventListener('click', factorize);
  document.getElementById('gcdButton')?.addEventListener('click', calculateGCD);
  document.getElementById('lcmButton')?.addEventListener('click', calculateLCM);

  // Enter 鍵支援
  document.getElementById('primeInput')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') checkPrime();
  });
  document.getElementById('factorInput')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') factorize();
  });
  // Enter triggers calculation from either input box for consistency.
  document.getElementById('gcdInput1')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') calculateGCD();
  });
  document.getElementById('gcdInput2')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') calculateGCD();
  });
  document.getElementById('lcmInput1')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') calculateLCM();
  });
  document.getElementById('lcmInput2')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') calculateLCM();
  });
</script>

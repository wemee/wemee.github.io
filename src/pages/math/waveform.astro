---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout currentPage="math" title="波形合成器">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <h1 class="text-center text-3xl font-bold text-base-50 mb-2">🎛️ 波形合成器</h1>
    <p class="text-center text-base-400 mb-6">疊加不同頻率的正弦波，親手把圓滑的波變成方波！</p>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <!-- 控制面板 -->
      <div class="space-y-4">
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 flex items-center justify-between">
            <span class="text-base-50">諧波控制</span>
            <button id="resetBtn" class="px-3 py-1 rounded border border-base-600 text-base-400 hover:bg-base-600 text-sm transition">重置</button>
          </div>
          <div id="harmonicControls" class="p-4 max-h-96 overflow-y-auto">
            <!-- 動態生成的滑桿 -->
          </div>
          <div class="px-4 py-3 border-t border-base-600 flex items-center justify-between">
            <span class="text-base-400">諧波數量:</span>
            <div class="flex">
              <button id="removeHarmonic" class="px-3 py-1 border border-base-600 rounded-l text-base-400 hover:bg-base-600 transition">-</button>
              <span id="harmonicCount" class="px-4 py-1 bg-base-600 text-base-50">5</span>
              <button id="addHarmonic" class="px-3 py-1 border border-base-600 rounded-r text-base-400 hover:bg-base-600 transition">+</button>
            </div>
          </div>
        </div>
        
        <!-- 預設波形 -->
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 text-base-50">快速載入預設波形</div>
          <div class="p-4 space-y-2">
            <button id="presetSquare" class="w-full px-4 py-2 rounded border border-accent-green text-accent-green hover:bg-accent-green/10 transition">方波 (Square)</button>
            <button id="presetSawtooth" class="w-full px-4 py-2 rounded border border-accent-cyan text-accent-cyan hover:bg-accent-cyan/10 transition">鋸齒波 (Sawtooth)</button>
            <button id="presetTriangle" class="w-full px-4 py-2 rounded border border-accent-yellow text-accent-yellow hover:bg-accent-yellow/10 transition">三角波 (Triangle)</button>
          </div>
        </div>
      </div>
      
      <!-- 波形顯示 -->
      <div class="lg:col-span-2 space-y-4">
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 text-base-50">時域波形 (Time Domain)</div>
          <div class="p-2">
            <canvas id="waveCanvas" width="700" height="200" class="w-full border border-base-600 rounded" style="aspect-ratio: 7 / 2; height: auto;"></canvas>
          </div>
        </div>
        <div class="rounded-lg border border-base-600 bg-base-800 overflow-hidden">
          <div class="px-4 py-3 bg-base-600/30 border-b border-base-600 text-base-50">頻譜 (Frequency Domain)</div>
          <div class="p-2">
            <canvas id="spectrumCanvas" width="700" height="150" class="w-full border border-base-600 rounded" style="aspect-ratio: 14 / 3; height: auto;"></canvas>
          </div>
        </div>
      </div>
    </div>
    
    <div class="text-center mt-6">
      <a href="/math/" class="px-4 py-2 rounded border border-base-600 text-base-400 hover:bg-base-600 transition">← 返回數學工具</a>
    </div>
  </div>
</BaseLayout>

<script>
  interface Harmonic {
    frequency: number;
    amplitude: number;
  }

  const waveCanvas = document.getElementById('waveCanvas') as HTMLCanvasElement;
  const spectrumCanvas = document.getElementById('spectrumCanvas') as HTMLCanvasElement;
  const waveCtx = waveCanvas.getContext('2d')!;
  const specCtx = spectrumCanvas.getContext('2d')!;
  
  let harmonics: Harmonic[] = [];
  let harmonicCount = 5;

  function init() {
    harmonics = [];
    for (let i = 1; i <= harmonicCount; i++) {
      harmonics.push({ frequency: i, amplitude: i === 1 ? 1 : 0 });
    }
    rebuildControls();
    draw();
  }

  // Build one slider row for a harmonic and wire its input handler. The row
  // updates only its own amplitude — full controls list rebuilding only
  // happens when harmonic count actually changes.
  function makeSliderRow(h: Harmonic, index: number): HTMLDivElement {
    const div = document.createElement('div');
    div.className = 'mb-4';
    div.dataset.harmonicIndex = index.toString();
    div.innerHTML = `
      <label class="flex justify-between text-sm mb-1">
        <span class="text-base-400">第 ${h.frequency} 諧波</span>
        <span class="text-accent-cyan harmonic-amp">${(h.amplitude * 100).toFixed(0)}%</span>
      </label>
      <input type="range" class="w-full harmonic-slider"
             min="0" max="100" value="${h.amplitude * 100}">
    `;
    const slider = div.querySelector('.harmonic-slider') as HTMLInputElement;
    const ampLabel = div.querySelector('.harmonic-amp') as HTMLSpanElement;
    slider.addEventListener('input', () => {
      harmonics[index].amplitude = parseInt(slider.value) / 100;
      ampLabel.textContent = (harmonics[index].amplitude * 100).toFixed(0) + '%';
      draw();
    });
    return div;
  }

  // Full rebuild — only call when harmonic count changes (init / add / remove
  // / preset). Dragging a slider must NOT trigger this or its focus is lost.
  function rebuildControls() {
    const container = document.getElementById('harmonicControls')!;
    container.innerHTML = '';
    harmonics.forEach((h, i) => container.appendChild(makeSliderRow(h, i)));
    document.getElementById('harmonicCount')!.textContent = harmonicCount.toString();
  }

  // Sync each slider's value + amplitude label without recreating DOM nodes,
  // so focus and active input survive. Used by preset buttons.
  function syncControlsToHarmonics() {
    const container = document.getElementById('harmonicControls')!;
    const rows = container.querySelectorAll<HTMLDivElement>('[data-harmonic-index]');
    rows.forEach((row) => {
      const idx = parseInt(row.dataset.harmonicIndex || '0');
      const h = harmonics[idx];
      if (!h) return;
      const slider = row.querySelector('.harmonic-slider') as HTMLInputElement;
      const ampLabel = row.querySelector('.harmonic-amp') as HTMLSpanElement;
      slider.value = (h.amplitude * 100).toString();
      ampLabel.textContent = (h.amplitude * 100).toFixed(0) + '%';
    });
  }

  function draw() {
    drawWave();
    drawSpectrum();
  }

  function drawWave() {
    const w = waveCanvas.width;
    const h = waveCanvas.height;
    const centerY = h / 2;
    
    waveCtx.fillStyle = '#002b36';
    waveCtx.fillRect(0, 0, w, h);
    
    // 中線
    waveCtx.strokeStyle = '#586e75';
    waveCtx.lineWidth = 1;
    waveCtx.beginPath();
    waveCtx.moveTo(0, centerY);
    waveCtx.lineTo(w, centerY);
    waveCtx.stroke();
    
    // 合成波
    waveCtx.strokeStyle = '#2aa198';
    waveCtx.lineWidth = 2;
    waveCtx.beginPath();
    
    for (let x = 0; x < w; x++) {
      const t = (x / w) * 4 * Math.PI;
      let y = 0;
      
      for (const h of harmonics) {
        y += h.amplitude * Math.sin(h.frequency * t);
      }
      
      const maxAmp = harmonics.reduce((sum, h) => sum + h.amplitude, 0) || 1;
      const normalizedY = centerY - (y / maxAmp) * (centerY - 20);
      
      if (x === 0) waveCtx.moveTo(x, normalizedY);
      else waveCtx.lineTo(x, normalizedY);
    }
    
    waveCtx.stroke();
    
    // 各諧波
    harmonics.forEach((h, i) => {
      if (h.amplitude === 0) return;
      
      const colors = ['#dc322f', '#2aa198', '#b58900', '#6c71c4', '#268bd2', '#859900'];
      waveCtx.strokeStyle = colors[i % colors.length] + '80';
      waveCtx.lineWidth = 1;
      waveCtx.beginPath();
      
      for (let x = 0; x < w; x++) {
        const t = (x / w) * 4 * Math.PI;
        const y = h.amplitude * Math.sin(h.frequency * t);
        const maxAmp = harmonics.reduce((sum, h) => sum + h.amplitude, 0) || 1;
        const normalizedY = centerY - (y / maxAmp) * (centerY - 20);
        
        if (x === 0) waveCtx.moveTo(x, normalizedY);
        else waveCtx.lineTo(x, normalizedY);
      }
      
      waveCtx.stroke();
    });
  }

  function drawSpectrum() {
    const w = spectrumCanvas.width;
    const h = spectrumCanvas.height;
    
    specCtx.fillStyle = '#002b36';
    specCtx.fillRect(0, 0, w, h);
    
    const barWidth = w / (harmonicCount + 1);
    const maxAmp = Math.max(...harmonics.map(h => h.amplitude), 0.1);
    
    harmonics.forEach((harm, i) => {
      const barHeight = (harm.amplitude / maxAmp) * (h - 30);
      const x = (i + 0.5) * barWidth;
      
      const gradient = specCtx.createLinearGradient(x, h - barHeight, x, h);
      gradient.addColorStop(0, '#2aa198');
      gradient.addColorStop(1, '#073642');
      
      specCtx.fillStyle = gradient;
      specCtx.fillRect(x - barWidth * 0.35, h - barHeight - 20, barWidth * 0.7, barHeight);
      
      specCtx.fillStyle = '#93a1a1';
      specCtx.font = '12px Arial';
      specCtx.textAlign = 'center';
      specCtx.fillText(`${harm.frequency}f`, x, h - 5);
    });
  }

  function loadSquareWave() {
    harmonics.forEach((h, i) => {
      const n = i + 1;
      h.amplitude = (n % 2 === 1) ? 1 / n : 0;
    });
    syncControlsToHarmonics();
    draw();
  }

  function loadSawtoothWave() {
    harmonics.forEach((h, i) => {
      const n = i + 1;
      h.amplitude = 1 / n;
    });
    syncControlsToHarmonics();
    draw();
  }

  function loadTriangleWave() {
    harmonics.forEach((h, i) => {
      const n = i + 1;
      if (n % 2 === 1) {
        const sign = ((n - 1) / 2) % 2 === 0 ? 1 : -1;
        h.amplitude = Math.abs(sign / (n * n));
      } else {
        h.amplitude = 0;
      }
    });
    syncControlsToHarmonics();
    draw();
  }

  document.getElementById('resetBtn')!.addEventListener('click', init);
  
  // Add appends only the new row; preserves focus/values on existing sliders.
  document.getElementById('addHarmonic')!.addEventListener('click', () => {
    if (harmonicCount < 20) {
      harmonicCount++;
      const h: Harmonic = { frequency: harmonicCount, amplitude: 0 };
      harmonics.push(h);
      document.getElementById('harmonicControls')!.appendChild(
        makeSliderRow(h, harmonics.length - 1)
      );
      document.getElementById('harmonicCount')!.textContent = harmonicCount.toString();
      draw();
    }
  });

  // Remove drops only the last row.
  document.getElementById('removeHarmonic')!.addEventListener('click', () => {
    if (harmonicCount > 1) {
      harmonicCount--;
      harmonics.pop();
      const container = document.getElementById('harmonicControls')!;
      const last = container.lastElementChild;
      if (last) container.removeChild(last);
      document.getElementById('harmonicCount')!.textContent = harmonicCount.toString();
      draw();
    }
  });

  document.getElementById('presetSquare')!.addEventListener('click', loadSquareWave);
  document.getElementById('presetSawtooth')!.addEventListener('click', loadSawtoothWave);
  document.getElementById('presetTriangle')!.addEventListener('click', loadTriangleWave);

  init();
</script>

<style>
  canvas {
    background: #002b36;
  }
</style>

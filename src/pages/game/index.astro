---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Map Bootstrap color names to Tailwind accent classes
const colorMap: Record<string, { bg: string; hover: string; border: string }> = {
  danger: { bg: 'bg-accent-red', hover: 'hover:bg-accent-red/80', border: 'border-accent-red' },
  info: { bg: 'bg-accent-cyan', hover: 'hover:bg-accent-cyan/80', border: 'border-accent-cyan' },
  warning: { bg: 'bg-accent-yellow', hover: 'hover:bg-accent-yellow/80', border: 'border-accent-yellow' },
  success: { bg: 'bg-accent-green', hover: 'hover:bg-accent-green/80', border: 'border-accent-green' },
  primary: { bg: 'bg-accent-blue', hover: 'hover:bg-accent-blue/80', border: 'border-accent-blue' },
};

const games = [
  {
    title: '🧩 數獨',
    description: '經典數獨遊戲！運用邏輯填滿 9x9 方格，支援鍵盤操作與計時',
    href: '/game/sudoku',
    color: 'danger'
  },
  {
    title: '⚪ 基礎碰撞',
    description: 'Phaser 3 物理引擎測試 - 完全彈性碰撞展示，球與球、球與牆壁的動量守恆',
    href: '/game/collision',
    color: 'info'
  },
  {
    title: '🎮 Phaser Demo',
    description: '使用 Phaser 3 引擎製作的熱血風格遊戲 Demo，支援角色移動與攻擊',
    href: '/game/phaser-demo',
    color: 'warning'
  },
  {
    title: '🏃 下樓梯',
    description: '經典的下樓梯遊戲！小心不要掉出去，也別被頂到頂部！',
    href: '/game/stairs',
    color: 'success'
  },
  {
    title: '🧱 打磚塊',
    description: '用彈跳球打破所有磚塊！經典 Breakout 遊戲的現代演繹',
    href: '/game/breakout',
    color: 'primary'
  },
  {
    title: '🐍 貪吃蛇',
    description: '經典貪吃蛇遊戲！控制小蛇吃食物，越長越好，別撞牆也別咬到自己！',
    href: '/game/snake',
    color: 'success'
  },
  {
    title: '🟦 俄羅斯方塊',
    description: '絢麗光影、強烈打擊感的俄羅斯方塊！可自訂板面尺寸、起始等級與主題色（賽博龐克 / 極光 / 火焰）',
    href: '/game/tetris',
    color: 'info'
  },
  {
    title: '🌀 迷宮產生演算法',
    description: '視覺化比較 DFS、BFS、Prim、Kruskal 等迷宮產生演算法的差異',
    href: '/maze/',
    color: 'warning'
  }
];
---
<BaseLayout currentPage="game" currentPage="game" title="遊戲">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
    <h1 class="text-center text-3xl font-bold text-base-50 mb-2">🎮 遊戲</h1>
    <p class="text-center text-base-400 mb-10">用 Canvas 打造的小遊戲</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 justify-items-center">
      {games.map((game) => {
        const colors = colorMap[game.color];
        return (
          <div class={`flex flex-col rounded-lg border ${colors.border} bg-base-800 h-full w-full max-w-sm`}>
            <div class="p-5 flex-1">
              <h5 class="text-lg font-semibold text-base-50 mb-2">{game.title}</h5>
              <p class="text-base-400">{game.description}</p>
            </div>
            <div class="px-5 pb-5">
              <a href={game.href} class={`block text-center px-4 py-2 rounded ${colors.bg} ${colors.hover} text-base-50 font-medium transition`}>
                開始遊戲
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>


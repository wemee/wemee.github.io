---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
---

<BaseLayout currentPage="game" title="基礎碰撞 - 物理引擎測試" description="使用 Phaser 3 Arcade Physics 展示完全彈性碰撞">
    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-12">
        <header class="text-center mb-6">
            <a href="/game" class="inline-block mb-3 text-sm text-accent-cyan hover:text-accent-cyan/80 transition">
                ← 返回遊戲列表
            </a>
            <h1 class="text-3xl font-bold text-base-50 mb-1">⚪ 基礎碰撞</h1>
            <p class="text-base-400 text-sm">Phaser 3 Arcade Physics · 完全彈性碰撞展示</p>
        </header>

        <div class="rounded-2xl bg-base-900 border border-base-600 p-2 mb-6 shadow-lg shadow-accent-cyan/5">
            <div id="game-canvas" class="rounded-xl overflow-hidden"></div>
        </div>

        <section class="grid gap-4 md:grid-cols-2">
            <div class="rounded-lg border border-base-600 bg-base-800 p-5">
                <h2 class="text-lg font-bold text-accent-cyan mb-3">物理說明</h2>
                <ul class="space-y-2 text-base-400 text-sm">
                    <li><strong class="text-accent-cyan">完全彈性碰撞</strong>：動能守恆、動量守恆</li>
                    <li><strong class="text-accent-cyan">無摩擦力</strong>：球體永遠不會停下來</li>
                    <li><strong class="text-accent-cyan">質量與面積成正比</strong>：大球質量較大</li>
                    <li><strong class="text-accent-cyan">牆壁反射</strong>：邊界完美反彈</li>
                </ul>
            </div>
            <div class="rounded-lg border border-base-600 bg-base-800 p-5">
                <h2 class="text-lg font-bold text-accent-cyan mb-3">技術資訊</h2>
                <ul class="space-y-2 text-base-400 text-sm">
                    <li><strong class="text-accent-cyan">物理引擎</strong>：Phaser Arcade Physics</li>
                    <li><strong class="text-accent-cyan">碰撞係數</strong>：bounce = 1.0（完全彈性）</li>
                    <li><strong class="text-accent-cyan">阻力</strong>：drag = 0、friction = 0</li>
                </ul>
            </div>
        </section>
    </main>

    <RelatedNotes currentPath="/game/collision/" />

    <script>
        import { initCollisionGame } from '@/lib/games/phaser/games/collision';

        document.addEventListener('DOMContentLoaded', () => {
            const game = initCollisionGame('game-canvas');

            window.addEventListener('beforeunload', () => {
                game.destroy();
            });
        });
    </script>
</BaseLayout>

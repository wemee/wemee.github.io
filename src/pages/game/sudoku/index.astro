---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SudokuBoard } from '@/components/sudoku/Board';
import { Controls } from '@/components/sudoku/Controls';
import { GameInfo } from '@/components/sudoku/GameInfo';
import { WinModal } from '@/components/sudoku/WinModal';
import '@/styles/global.css';
---

<BaseLayout currentPage="game" title="數獨 - 挫屎勇的個人網站" description="經典數獨遊戲！運用邏輯填滿 9x9 方格，支援鍵盤操作與計時">
  
  <!-- Tailwind Scoped Container -->
  <div class="container mt-5 mb-5">
    <div class="max-w-2xl mx-auto">
      <header class="text-center mb-4">
        <h1 class="text-4xl font-extrabold text-base-50 tracking-widest mb-2">
          SUDOKU
        </h1>
        <p class="text-sm text-base-400 uppercase tracking-wider">
          Pure Logic. Pure Zen.
        </p>
      </header>

      <!-- Tailwind-styled game area -->
      <div class="p-6 bg-base-800/50 backdrop-blur-md rounded-3xl border border-base-600 relative">
        <WinModal client:only="react" />
        <GameInfo client:only="react" />
        <SudokuBoard client:only="react" />
        <Controls client:only="react" />
      </div>

      <!-- Link to standalone version -->
      <div class="text-center mt-4">
        <a href="/sudoku" class="text-sm text-accent-blue hover:text-accent-blue/80 hover:underline transition-colors">
          🎮 切換至全螢幕沉浸模式
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

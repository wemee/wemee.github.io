---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
import '@/styles/game-common.css';
---
<BaseLayout
  title="下樓梯遊戲 | 挫屎勇的遊戲間"
  description="經典反應遊戲「下樓梯」，挑戰你的反應極限！是男人就下 100 層。支援觸控、鍵盤、規則 AI 與強化學習 AI 自動遊玩模式。"
  currentPage="game"
>
  <!-- 載入 TensorFlow.js for RL AI -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.22.0/dist/tf.min.js"></script>
  <div class="w-full px-4 mt-6">
    <div class="flex justify-center">
      <div class="inline-block">
        <div class="game-container">
          <canvas id="gameCanvas" width="400" height="600"></canvas>
          <div class="game-overlay" id="startScreen">
            <h2>🏃 下樓梯</h2>
            <p>不要掉出去，也別被頂到頂部！</p>
            <button class="px-6 py-3 text-lg rounded bg-accent-green hover:bg-accent-green/80 text-base-50 font-medium transition" id="startBtn">開始遊戲</button>
            <button class="px-6 py-3 text-lg rounded bg-accent-yellow hover:bg-accent-yellow/80 text-base-900 font-medium transition mt-2" id="aiStartBtn">🤖 規則 AI</button>
            <button class="px-6 py-3 text-lg rounded bg-accent-cyan hover:bg-accent-cyan/80 text-base-50 font-medium transition mt-2" id="rlAiStartBtn">🧠 強化學習 AI</button>
            <div class="controls-info mt-3">
              <small>← → 或 A D 移動 | 空白鍵暫停</small>
            </div>
            <div id="rlAiLoadingInfo" class="mt-2 hidden">
              <small class="text-accent-cyan">🧠 正在載入 RL 模型...</small>
            </div>
          </div>
          <div class="game-overlay hidden" id="gameOverScreen">
            <h2>💀 遊戲結束</h2>
            <p>分數: <span id="finalScore">0</span></p>
            <p>最高分: <span id="highScore">0</span></p>
            <button class="px-6 py-3 text-lg rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition" id="restartBtn">再玩一次</button>
          </div>
          <div class="game-overlay hidden" id="pauseScreen">
            <h2>⏸️ 暫停</h2>
            <p>按空白鍵繼續</p>
          </div>
          <div class="score-display">
            <span id="aiIndicator" class="hidden">🤖 </span>
            <span id="scoreDisplay">0</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <RelatedNotes currentPath="/game/stairs/" />
</BaseLayout>

<script>
  import { StairsGame } from '@/lib/games/StairsGame';
  import { StairsWeightsAgent } from '@/lib/ai/agents/StairsWeightsAgent';

  // RL AI 支援
  let rlAgent: StairsWeightsAgent | null = null;
  let game: StairsGame | null = null;

  // 載入 RL AI
  const loadRLAgent = async () => {
    const loadingInfo = document.getElementById('rlAiLoadingInfo');
    const rlAiBtn = document.getElementById('rlAiStartBtn') as HTMLButtonElement;

    if (rlAgent) return; // 已載入

    try {
      loadingInfo?.classList.remove('hidden');
      rlAiBtn.disabled = true;
      rlAiBtn.textContent = '🧠 載入中...';

      rlAgent = new StairsWeightsAgent({
        weightsPath: '/models/stairs/model_weights.json',
        deterministic: true
      });

      await rlAgent.load();

      rlAiBtn.textContent = '🧠 強化學習 AI';
      rlAiBtn.disabled = false;
      loadingInfo?.classList.add('hidden');

      console.log('✅ RL AI loaded successfully');

      // 銷毀舊的遊戲實例（停止遊戲循環）
      if (game) {
        game.destroy();
        console.log('🧹 Old game instance destroyed');
      }

      // 重新創建遊戲實例，這次傳入 RL agent
      game = new StairsGame(rlAgent);

      return true;
    } catch (error) {
      console.error('❌ Failed to load RL AI:', error);
      rlAiBtn.textContent = '🧠 載入失敗';
      loadingInfo!.innerHTML = '<small class="text-danger">載入失敗，請檢查控制台</small>';
      return false;
    }
  };

  // RL AI 按鈕事件
  document.getElementById('rlAiStartBtn')?.addEventListener('click', async () => {
    if (!rlAgent) {
      const loaded = await loadRLAgent();
      if (!loaded) return;
    }

    if (rlAgent && game) {
      // 開始 RL AI 模式
      game.startGame('rl');
    }
  });

  // 初始化遊戲（沒有 RL agent）
  game = new StairsGame();

  // 預載 RL AI (可選 - 取消註解以提前載入模型)
  // setTimeout(() => loadRLAgent().catch(console.error), 1000);
</script>

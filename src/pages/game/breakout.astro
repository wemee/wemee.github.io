---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
import '@/styles/game-common.css';
---
<BaseLayout currentPage="game" 
  title="打磚塊 | 挫屎勇的遊戲間" 
  description="經典復古的打磚塊遊戲，挑戰反應神經！內含超強 AI 自動遊玩模式 (AI 模式)，來看看演算法是怎麼過關的。"
>
  <div class="w-full px-4 mt-6">
    <div class="flex justify-center">
      <div class="inline-block">
        <div class="game-container">
          <canvas id="gameCanvas" width="480" height="600"></canvas>
          <div class="game-overlay" id="startScreen">
            <h2>🧱 打磚塊</h2>
            <p>打破所有磚塊！</p>
            <button class="px-6 py-3 text-lg rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition" id="startBtn">開始遊戲</button>
            <button class="px-6 py-3 text-lg rounded bg-accent-yellow hover:bg-accent-yellow/80 text-base-900 font-medium transition mt-2" id="aiStartBtn">🤖 AI 模式</button>
            <div class="controls-info mt-3">
              <small>← → 或 滑鼠移動板子<br>空白鍵或點擊發球</small>
            </div>
          </div>
          <div class="game-overlay hidden" id="winScreen">
            <h2>🎉 恭喜過關！</h2>
            <p>分數: <span id="winScore">0</span></p>
            <button class="px-6 py-3 text-lg rounded bg-accent-green hover:bg-accent-green/80 text-base-50 font-medium transition" id="nextLevelBtn">下一關</button>
          </div>
          <div class="game-overlay hidden" id="gameOverScreen">
            <h2>💀 遊戲結束</h2>
            <p>最終分數: <span id="finalScore">0</span></p>
            <button class="px-6 py-3 text-lg rounded bg-accent-blue hover:bg-accent-blue/80 text-base-50 font-medium transition" id="restartBtn">再玩一次</button>
          </div>
          <div class="game-hud">
            <span class="hud-item">分數: <span id="scoreDisplay">0</span></span>
            <span class="hud-item"><span id="aiIndicator" class="hidden">🤖 AI</span> 生命: <span id="livesDisplay">❤️❤️❤️</span></span>
            <span class="hud-item">關卡: <span id="levelDisplay">1</span></span>
          </div>
        </div>
        <div class="text-center mt-4">
          <a href="/game/" class="inline-block px-4 py-2 rounded border border-base-600 text-base-400 hover:bg-base-600 transition">← 返回遊戲列表</a>
        </div>
      </div>
    </div>
  </div>

  <RelatedNotes currentPath="/game/breakout/" />
</BaseLayout>

<script>
  import { BreakoutGame } from '@/lib/games/BreakoutGame';
  
  // 啟動遊戲
  new BreakoutGame();
</script>

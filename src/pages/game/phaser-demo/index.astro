---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
---

<BaseLayout currentPage="game" title="Phaser 3 Demo - 熱血風格遊戲引擎測試" description="使用 Phaser 3 製作的像素風格遊戲 Demo">
    <main class="game-container">
        <div class="game-header">
            <a href="/game" class="back-link">← 返回遊戲列表</a>
            <h1>🎮 Phaser 3 Demo</h1>
            <p class="subtitle">熱血風格遊戲引擎測試</p>
        </div>

        <div class="game-wrapper">
            <div id="game-canvas" class="game-canvas"></div>
        </div>

        <div class="controls-info">
            <h2>操作說明</h2>
            <div class="controls-grid">
                <div class="control-item">
                    <kbd>↑</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd>
                    <span>移動</span>
                </div>
                <div class="control-item">
                    <kbd>Space</kbd>
                    <span>攻擊</span>
                </div>
            </div>
        </div>

        <div class="tech-info">
            <h2>技術資訊</h2>
            <ul>
                <li><strong>遊戲引擎</strong>：Phaser 3</li>
                <li><strong>渲染模式</strong>：WebGL（自動回退 Canvas）</li>
                <li><strong>物理引擎</strong>：Arcade Physics</li>
                <li><strong>角色系統</strong>：Sprite Sheet 動畫</li>
            </ul>
        </div>
    </main>

    <RelatedNotes currentPath="/game/phaser-demo/" />

    <script>
        import { initDemoGame } from '@/lib/games/phaser/games/demo';

        // 等待 DOM 載入完成
        document.addEventListener('DOMContentLoaded', () => {
            const game = initDemoGame('game-canvas');

            // 頁面離開時清理
            window.addEventListener('beforeunload', () => {
                game.destroy();
            });
        });
    </script>

    <style>
        .game-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .game-header {
            text-align: center;
            margin-bottom: 2rem;
            color: #fff;
        }

        .back-link {
            color: #00ff88;
            text-decoration: none;
            font-size: 0.9rem;
            display: inline-block;
            margin-bottom: 1rem;
            transition: color 0.2s;
        }

        .back-link:hover {
            color: #00ffaa;
        }

        .game-header h1 {
            font-size: 2.5rem;
            margin: 0;
            text-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
        }

        .subtitle {
            color: #888;
            margin-top: 0.5rem;
        }

        .game-wrapper {
            background: #000;
            border-radius: 16px;
            padding: 8px;
            box-shadow: 
                0 0 40px rgba(0, 255, 136, 0.2),
                inset 0 0 20px rgba(0, 0, 0, 0.5);
        }

        .game-canvas {
            border-radius: 8px;
            overflow: hidden;
        }

        .controls-info, .tech-info {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin-top: 2rem;
            color: #fff;
            max-width: 480px;
            width: 100%;
        }

        .controls-info h2, .tech-info h2 {
            font-size: 1.2rem;
            margin-bottom: 1rem;
            color: #00ff88;
        }

        .controls-grid {
            display: flex;
            gap: 2rem;
            justify-content: center;
        }

        .control-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        kbd {
            background: linear-gradient(180deg, #444 0%, #333 100%);
            border: 1px solid #555;
            border-radius: 4px;
            padding: 0.3rem 0.6rem;
            font-family: monospace;
            font-size: 0.9rem;
            box-shadow: 0 2px 0 #222;
            margin: 0 2px;
        }

        .control-item span {
            font-size: 0.85rem;
            color: #aaa;
        }

        .tech-info ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .tech-info li {
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .tech-info li:last-child {
            border-bottom: none;
        }

        .tech-info strong {
            color: #00ff88;
        }

        @media (max-width: 520px) {
            .game-container {
                padding: 1rem;
            }

            .game-header h1 {
                font-size: 1.8rem;
            }

            .controls-grid {
                flex-direction: column;
                gap: 1rem;
            }
        }
    </style>
</BaseLayout>


---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
---

<BaseLayout currentPage="game" title="Phaser 3 Demo - 熱血風格遊戲引擎測試" description="使用 Phaser 3 製作的像素風格遊戲 Demo">
    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-12">
        <header class="text-center mb-6">
            <a href="/game" class="inline-block mb-3 text-sm text-accent-green hover:text-accent-green/80 transition">
                ← 返回遊戲列表
            </a>
            <h1 class="text-3xl font-bold text-base-50 mb-1">🎮 Phaser 3 Demo</h1>
            <p class="text-base-400 text-sm">熱血風格遊戲引擎測試</p>
        </header>

        <div class="rounded-2xl bg-base-900 border border-base-600 p-2 mb-6 shadow-lg shadow-accent-green/5">
            <div id="game-canvas" class="rounded-xl overflow-hidden"></div>
        </div>

        <section class="grid gap-4 md:grid-cols-2">
            <div class="rounded-lg border border-base-600 bg-base-800 p-5">
                <h2 class="text-lg font-bold text-accent-green mb-3">操作說明</h2>
                <div class="flex justify-center gap-8 text-sm text-base-400">
                    <div class="flex flex-col items-center gap-2">
                        <div class="flex gap-1">
                            <kbd class="px-2 py-1 bg-base-700 border border-base-600 rounded text-xs font-mono text-base-50">↑</kbd>
                            <kbd class="px-2 py-1 bg-base-700 border border-base-600 rounded text-xs font-mono text-base-50">↓</kbd>
                            <kbd class="px-2 py-1 bg-base-700 border border-base-600 rounded text-xs font-mono text-base-50">←</kbd>
                            <kbd class="px-2 py-1 bg-base-700 border border-base-600 rounded text-xs font-mono text-base-50">→</kbd>
                        </div>
                        <span>移動</span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        <kbd class="px-2 py-1 bg-base-700 border border-base-600 rounded text-xs font-mono text-base-50">Space</kbd>
                        <span>攻擊</span>
                    </div>
                </div>
            </div>
            <div class="rounded-lg border border-base-600 bg-base-800 p-5">
                <h2 class="text-lg font-bold text-accent-green mb-3">技術資訊</h2>
                <ul class="space-y-2 text-base-400 text-sm">
                    <li><strong class="text-accent-green">遊戲引擎</strong>：Phaser 3</li>
                    <li><strong class="text-accent-green">渲染模式</strong>：WebGL（自動回退 Canvas）</li>
                    <li><strong class="text-accent-green">物理引擎</strong>：Arcade Physics</li>
                    <li><strong class="text-accent-green">角色系統</strong>：Sprite Sheet 動畫</li>
                </ul>
            </div>
        </section>
    </main>

    <RelatedNotes currentPath="/game/phaser-demo/" />

    <script>
        import { initDemoGame } from '@/lib/games/phaser/games/demo';

        document.addEventListener('DOMContentLoaded', () => {
            const game = initDemoGame('game-canvas');

            window.addEventListener('beforeunload', () => {
                game.destroy();
            });
        });
    </script>
</BaseLayout>

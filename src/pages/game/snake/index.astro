---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RelatedNotes from '@/components/RelatedNotes.astro';
import { SnakeGame } from '@/components/games/snake';
---

<BaseLayout
    title="貪吃蛇 | Snake Game"
    description="經典貪吃蛇遊戲，支援鍵盤與觸控操作"
    currentPage="game"
>
    <div class="min-h-[60vh] flex flex-col items-center justify-center py-8">
        <h1 class="text-3xl font-bold text-base-50 mb-6">🐍 貪吃蛇</h1>
        <SnakeGame client:load />
    </div>

    <RelatedNotes currentPath="/game/snake/" />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrackCard from '@/components/lab/TrackCard.astro';
import { tracks, learningStages, getTrack } from '@/data/labTracks';
import { getCollection } from 'astro:content';

const lessons = await getCollection('lab');
const lessonCount = lessons.filter((l) => !l.data.draft).length;
const moduleCount = tracks.reduce((n, t) => n + t.modules.length, 0);
const trackCount = tracks.length;

// 每一站的強調樣式。用完整 class 字串（Tailwind 掃不到動態拼接的 class）。
const stageStyles: Record<string, { step: string; border: string; pillHover: string }> = {
  foundations: { step: 'text-accent-cyan', border: 'border-accent-cyan', pillHover: 'hover:border-accent-cyan' },
  'ml-core': { step: 'text-accent-green', border: 'border-accent-green', pillHover: 'hover:border-accent-green' },
  'deep-applications': { step: 'text-accent-red', border: 'border-accent-red', pillHover: 'hover:border-accent-red' },
};
const fallbackStyle = stageStyles.foundations;
---

<BaseLayout
  title="程式實驗室"
  description="動手學程式與 AI——8 條學習軌道、80 堂課，每堂都附一個可在 Google Colab 直接執行的 notebook。從畫圖、看懂資料，一路到大型語言模型、AI Agent 與生成式影像。"
  currentPage="lab"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Hero -->
    <div class="mb-10 text-center">
      <h1 class="mb-3 text-4xl font-bold text-base-50">🧪 程式實驗室</h1>
      <p class="mx-auto max-w-2xl text-lg text-base-300">
        動手學程式與 AI。每堂課都附一個可在 <span class="text-accent-yellow">Google Colab</span> 直接執行的 notebook——看得到、改得動、跑得起來。
      </p>
      <div class="mt-6 flex items-center justify-center gap-4 text-sm text-base-400 sm:gap-5">
        <span><strong class="text-xl font-bold text-base-100">{trackCount}</strong> 軌道</span>
        <span class="text-base-600">·</span>
        <span><strong class="text-xl font-bold text-base-100">{moduleCount}</strong> 模組</span>
        <span class="text-base-600">·</span>
        <span><strong class="text-xl font-bold text-base-100">{lessonCount}</strong> 堂課</span>
      </div>
    </div>

    <!-- 學習地圖：建議路徑 -->
    <div class="mb-14 rounded-2xl border border-base-700 bg-base-800/50 p-6 sm:p-8">
      <h2 class="text-lg font-semibold text-base-100">不知道從哪開始？跟著這條路走</h2>
      <p class="mt-2 text-sm leading-relaxed text-base-400">
        照「基礎 → 核心 → 應用」三站循序漸進。零基礎就從<span class="text-accent-cyan">第一站</span>開始；卡片上的「建議先學」會告訴你進階軌道的前置課程。
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-2 text-sm">
        {
          learningStages.map((stage, i) => (
            <Fragment>
              {i > 0 && <span class="text-base-600">→</span>}
              <a
                href={`#${stage.id}`}
                class={`rounded-full border border-base-700 bg-base-900/40 px-3 py-1 text-base-200 transition hover:text-base-50 ${(stageStyles[stage.id] ?? fallbackStyle).pillHover}`}
              >
                {stage.title}
              </a>
            </Fragment>
          ))
        }
      </div>
    </div>

    <!-- 各學習階段 -->
    {
      learningStages.map((stage) => {
        const s = stageStyles[stage.id] ?? fallbackStyle;
        return (
          <section id={stage.id} class="mb-16 scroll-mt-24">
            <div class={`border-l-2 pl-4 ${s.border}`}>
              <span class={`font-mono text-sm ${s.step}`}>{stage.step}</span>
              <h2 class="text-2xl font-bold text-base-50">{stage.title}</h2>
              <p class="mt-1 text-sm text-base-400">{stage.subtitle}</p>
            </div>
            <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {stage.trackIds.map((id) => {
                const track = getTrack(id);
                return track ? <TrackCard track={track} /> : null;
              })}
            </div>
          </section>
        );
      })
    }

    <!-- 收尾 -->
    <div class="rounded-2xl border border-base-700 bg-base-800/50 p-6 text-center sm:p-8">
      <p class="text-sm leading-relaxed text-base-400">
        每堂課的 notebook 都存在 <a href="https://github.com/wemee/wemee.github.io/tree/main/notebooks" class="text-accent-yellow underline-offset-2 hover:underline">GitHub repo</a> 裡，點課程頁的「Open in Colab」即可在免費的雲端 GPU 上一鍵執行。看得到原始碼、改得動、跑得起來——這才叫動手學。
      </p>
    </div>
  </div>
</BaseLayout>

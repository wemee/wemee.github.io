---
import { getSectionNav } from '@/lib/math/mathSections';

interface Props {
  /** section id: 'linalg' | 'calculus' | 'probstat' */
  section: string;
  /** current page slug */
  slug: string;
}

const { section, slug } = Astro.props;
const { prev, next, supplements, indexHref, indexLabel } = getSectionNav(section, slug);
---
<section class="mt-12 max-w-3xl mx-auto">
  {supplements.length > 0 && (
    <div class="rounded-lg border border-accent-yellow/40 bg-base-800/60 p-5 mb-6">
      <h3 class="text-lg font-bold text-accent-yellow mb-3">📚 補充閱讀</h3>
      <ul class="space-y-2 text-base-300 text-sm">
        {supplements.map((s) => (
          <li class="flex flex-col sm:flex-row sm:items-baseline sm:gap-2">
            {s.href ? (
              <a href={s.href} class="text-accent-blue hover:underline font-medium">{s.label}</a>
            ) : (
              <span class="text-base-50 font-medium">{s.label}</span>
            )}
            {s.description && <span class="text-base-400">— {s.description}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  <nav class="grid grid-cols-1 sm:grid-cols-2 gap-3" aria-label="課程導覽">
    <div>
      {prev ? (
        <a href={prev.href} class="block rounded-lg border border-base-600 hover:border-accent-blue bg-base-800 p-4 transition h-full">
          <div class="text-xs text-base-400 mb-1">← 上一頁 · {prev.chapter}</div>
          <div class="text-base-50 font-bold">{prev.emoji} {prev.title}</div>
        </a>
      ) : (
        <a href={indexHref} class="block rounded-lg border border-base-600 hover:border-accent-blue bg-base-800 p-4 transition h-full">
          <div class="text-xs text-base-400 mb-1">←</div>
          <div class="text-base-50 font-bold">{indexLabel}</div>
        </a>
      )}
    </div>
    <div>
      {next ? (
        <a href={next.href} class="block rounded-lg border border-base-600 hover:border-accent-blue bg-base-800 p-4 transition h-full text-right">
          <div class="text-xs text-base-400 mb-1">下一頁 · {next.chapter} →</div>
          <div class="text-base-50 font-bold">{next.emoji} {next.title}</div>
        </a>
      ) : (
        <a href={indexHref} class="block rounded-lg border border-base-600 hover:border-accent-blue bg-base-800 p-4 transition h-full text-right">
          <div class="text-xs text-base-400 mb-1">回專區 →</div>
          <div class="text-base-50 font-bold">{indexLabel}</div>
        </a>
      )}
    </div>
  </nav>
</section>

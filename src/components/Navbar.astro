      { href: '/math/dot-product', label: '🏹 向量內積視覺化' },
      { href: '/math/traffic', label: '🚗 交通流體力學' },
    ]
  },
  {
    label: '程式實驗室',
    key: 'lab',
    items: [
      { href: '/lab/', label: '🧪 全部課程' },
      { divider: true },
      { href: '/lab/python/', label: '🐍 Python' },
      { href: '/lab/python/matplotlib/', label: '　📊 matplotlib 資料視覺化' },
      { divider: true },
      { href: '/lab/ds/', label: '📈 資料科學' },
      { href: '/lab/ds/data-analysis/', label: '　🔍 資料分析實戰' },
      { divider: true },
      { href: '/lab/ml/', label: '🤖 機器學習' },
      { href: '/lab/ml/scikit-learn/', label: '　🧠 scikit-learn 入門' },
      { href: '/lab/ml/boosting/', label: '　🌲 梯度提升與集成學習' },
      { href: '/lab/ml/pytorch/', label: '　🔥 深度學習（PyTorch）' },
      { divider: true },
      { href: '/lab/rl/', label: '🎮 強化學習' },
      { href: '/lab/rl/from-scratch/', label: '　🕹️ 手刻強化學習' },
      { divider: true },
      { href: '/lab/cv/', label: '📷 電腦視覺' },
      { href: '/lab/cv/deep-vision/', label: '　👁️ 深度電腦視覺' },
      { divider: true },
      { href: '/lab/llm/', label: '💬 大型語言模型' },
      { href: '/lab/llm/from-scratch/', label: '　🛠️ 從零打造迷你 GPT' },
